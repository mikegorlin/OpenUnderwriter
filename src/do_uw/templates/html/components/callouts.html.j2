{# Callout box macros for Bloomberg-quality D&O worksheet HTML output.
   Discovery boxes, warning boxes, D&O context notes, gap notices,
   SCR (Situation-Complication-Resolution) narrative blocks (NARR-04),
   and D&O implications callout boxes (NARR-06). #}


{# Discovery callout for blind spot / proactive findings.
   Gold left border, light gold background.
   Per user decision on distinct blind spot callout boxes. #}
{% macro discovery_box(title, content) %}
<div class="discovery-box border-l-4 border-gold bg-gold-light rounded-r px-4 py-3 my-3 page-break-inside-avoid">
  <p class="font-heading text-sm font-semibold text-navy m-0 mb-1">
    {{ title }}
  </p>
  <div class="text-sm text-gray-700 leading-relaxed">
    {{ content }}
  </div>
</div>
{% endmacro %}


{# Warning callout for ELEVATED density items.
   Amber border and background with optional D&O context note. #}
{% macro warning_box(description, do_context_text="") %}
<div class="warning-box border-l-4 border-amber-500 bg-amber-50 rounded-r px-4 py-3 my-3 page-break-inside-avoid">
  <div class="text-sm text-gray-800 leading-relaxed">
    {{ description }}
  </div>
  {% if do_context_text %}
  <p class="font-body text-xs italic text-navy mt-2 mb-0">
    {{ do_context_text }}
  </p>
  {% endif %}
</div>
{% endmacro %}


{# D&O context note explaining "why this matters for D&O".
   Small italic navy text for ELEVATED indicator explanations.
   Per user decision on contextual ELEVATED indicators. #}
{% macro do_context(text) %}
<p class="text-xs italic text-navy my-1 leading-relaxed">
  {{ text }}
</p>
{% endmacro %}


{# Gap notice for unavailable data.
   Grey "Data not available" notice with explanation.
   Per user decision on per-subsection gap notices. #}
{% macro gap_notice(field_name, reason="") %}
<div class="gap-notice bg-gray-50 border border-gray-200 rounded px-4 py-2 my-2 text-sm text-gray-500 italic">
  <span class="font-semibold not-italic">{{ field_name }}:</span>
  {% if reason %}
    {{ reason }}
  {% else %}
    Data not available
  {% endif %}
</div>
{% endmacro %}


{# SCR (Situation-Complication-Resolution) narrative block (NARR-04).
   Structured analytical framework per section. Navy top border,
   three labeled segments. Renders only when all three parts present. #}
{% macro scr_narrative(scr) %}
{%- if scr and scr.situation and scr.complication and scr.resolution -%}
<div class="scr-block border-t-2 border-navy bg-slate-50 rounded px-4 py-3 my-3 page-break-inside-avoid">
  <p class="font-heading text-[10px] font-semibold text-navy uppercase tracking-widest mb-2 mt-0">
    Analytical Framework
  </p>
  <div class="scr-segments">
    <div class="scr-segment mb-2">
      <span class="scr-label font-heading text-xs font-semibold text-gray-500 uppercase tracking-wide">Situation</span>
      <p class="font-body text-sm text-gray-700 leading-relaxed m-0 mt-0.5">{{ scr.situation }}</p>
    </div>
    <div class="scr-segment mb-2">
      <span class="scr-label font-heading text-xs font-semibold text-amber-600 uppercase tracking-wide">Complication</span>
      <p class="font-body text-sm text-gray-700 leading-relaxed m-0 mt-0.5">{{ scr.complication }}</p>
    </div>
    <div class="scr-segment">
      <span class="scr-label font-heading text-xs font-semibold text-emerald-600 uppercase tracking-wide">Resolution</span>
      <p class="font-body text-sm text-gray-700 leading-relaxed m-0 mt-0.5">{{ scr.resolution }}</p>
    </div>
  </div>
</div>
{%- endif -%}
{% endmacro %}


{# D&O Implications callout box (NARR-06).
   Navy-blue left border with shield icon. Shows D&O-specific risk
   implications derived from section analysis. Renders in every section
   when implications data is available. #}
{% macro do_implications(impl) %}
{%- if impl and impl.get('items') -%}
<div class="do-implications border-l-4 border-navy bg-blue-50 rounded-r px-4 py-3 my-3 page-break-inside-avoid">
  <p class="font-heading text-[10px] font-semibold text-navy uppercase tracking-widest mb-1.5 mt-0">
    D&amp;O Implications
  </p>
  <ul class="my-0 ml-4 space-y-1 list-disc">
    {% for item in impl.get('items') %}
    <li class="text-sm text-gray-700 leading-relaxed">
      {%- if item.severity == 'HIGH' -%}
        <span class="font-semibold text-red-700">{{ item.text }}</span>
      {%- elif item.severity == 'MEDIUM' -%}
        <span class="font-semibold text-amber-700">{{ item.text }}</span>
      {%- else -%}
        {{ item.text }}
      {%- endif -%}
    </li>
    {% endfor %}
  </ul>
  {% if impl.coverage_note %}
  <p class="font-body text-xs italic text-navy mt-2 mb-0">
    {{ impl.coverage_note }}
  </p>
  {% endif %}
</div>
{%- endif -%}
{% endmacro %}
