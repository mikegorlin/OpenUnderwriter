{# Board Cross-Exposure Network — maps director interlocks and conflict potential.
   Data: b.investigative.board_cross_exposure (list of directors with external boards) #}
{% set bce = b.investigative.board_cross_exposure if b.investigative else [] %}
{% if bce %}
<div style="margin:8px 0">
  <div style="background:#F3F4F6;padding:4px 8px;border-radius:3px;margin-bottom:4px;display:flex;justify-content:space-between;align-items:center">
    <span style="font-size:9pt;font-weight:700;color:#1F3A5C">Board Cross-Exposure Network</span>
    <span style="font-size:7pt;color:#6B7280">{{ bce | length }} directors with external seats</span>
  </div>
  <div style="background:white;border:1px solid #E5E7EB;border-radius:5px;overflow:hidden">
    {% for d in bce %}
    <div style="padding:6px 10px;{% if not loop.last %}border-bottom:1px solid #F3F4F6;{% endif %}">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:3px">
        <div>
          <span style="font-size:9pt;font-weight:600;color:#111827">{{ d.name }}</span>
          {% if d.is_overboarded %}
          <span style="padding:1px 5px;border-radius:6px;font-size:6pt;font-weight:700;background:#FEF2F2;color:#DC2626;margin-left:4px">OVERBOARDED</span>
          {% endif %}
        </div>
        <span style="font-size:7pt;color:#6B7280;font-weight:600">{{ d.total_seats }} total seats</span>
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:3px">
        {% for ob in d.other_boards %}
        <div style="display:inline-flex;align-items:center;gap:3px;padding:2px 6px;border-radius:4px;font-size:7pt;background:#F3F4F6;border:1px solid #E5E7EB">
          <span style="font-weight:600;color:#374151">{{ ob.company }}</span>
          {% if ob.exposure and ob.exposure != 'Other' %}
          <span style="color:#6B7280;font-size:6pt">{{ ob.exposure }}</span>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}
