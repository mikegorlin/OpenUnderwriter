{# Revenue-at-Risk Analysis — quantifies revenue exposed to key risk factors.
   Data: b.investigative.revenue_at_risk (list of risk items) #}
{% set rar = b.investigative.revenue_at_risk if b.investigative else [] %}
{% if rar %}
<div style="margin:8px 0">
  <div style="background:#F3F4F6;padding:4px 8px;border-radius:3px;margin-bottom:4px;display:flex;justify-content:space-between;align-items:center">
    <span style="font-size:9pt;font-weight:700;color:#1F3A5C">Revenue at Risk</span>
    <span style="font-size:7pt;color:#6B7280">Quantified exposure by risk factor</span>
  </div>
  <div style="background:white;border:1px solid #E5E7EB;border-radius:5px;overflow:hidden">
    <table style="width:100%;border-collapse:collapse;font-size:8pt">
      <tr style="background:#F9FAFB;border-bottom:1px solid #E5E7EB">
        <th style="padding:4px 8px;text-align:left;font-weight:600;color:#6B7280;font-size:7pt;text-transform:uppercase;letter-spacing:0.3px">Risk Factor</th>
        <th style="padding:4px 8px;text-align:right;font-weight:600;color:#6B7280;font-size:7pt;text-transform:uppercase;letter-spacing:0.3px">Amount</th>
        <th style="padding:4px 8px;text-align:right;font-weight:600;color:#6B7280;font-size:7pt;text-transform:uppercase;letter-spacing:0.3px">% Rev</th>
        <th style="padding:4px 8px;text-align:left;font-weight:600;color:#6B7280;font-size:7pt;text-transform:uppercase;letter-spacing:0.3px;width:55%">D&amp;O Relevance</th>
      </tr>
      {% for r in rar %}
      <tr style="{% if not loop.last %}border-bottom:1px solid #F3F4F6;{% endif %}">
        <td style="padding:5px 8px;font-weight:600;color:#111827;white-space:nowrap">
          <span style="display:inline-block;width:6px;height:6px;border-radius:3px;background:{% if r.severity == 'HIGH' %}#DC2626{% else %}#F59E0B{% endif %};margin-right:4px;vertical-align:middle"></span>
          {{ r.risk }}
        </td>
        <td style="padding:5px 8px;text-align:right;font-weight:700;color:#111827;font-variant-numeric:tabular-nums">{{ r.amount }}</td>
        <td style="padding:5px 8px;text-align:right;color:#6B7280;font-variant-numeric:tabular-nums">{{ r.pct }}</td>
        <td style="padding:5px 8px;color:#4B5563;line-height:1.4">{{ r.detail }}</td>
      </tr>
      {% endfor %}
    </table>
  </div>
</div>
{% endif %}
