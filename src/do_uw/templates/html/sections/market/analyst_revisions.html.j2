{# Analyst Revisions — EPS revision trends + price target range.
   Data from mkt.eps_revisions and mkt.analyst_targets.
   Phase 133-02: STOCK-06. #}

{% if mkt.get('eps_revisions') or mkt.get('analyst_targets') %}
  <h3>Analyst Revision Trends</h3>

  {# EPS Revision Trends Table #}
  {% set rev = mkt.get('eps_revisions', []) %}
  {% if rev %}
  <table class="w-full border-collapse my-3 text-sm">
    <thead>
      <tr class="bg-navy text-white">
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-left p-1">Period</th>
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right p-1">Up (7d)</th>
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right p-1">Down (7d)</th>
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right p-1">Up (30d)</th>
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right p-1">Down (30d)</th>
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-center p-1">Net</th>
      </tr>
    </thead>
    <tbody class="tabular-nums">
      {% for r in rev %}
      <tr class="{{ 'bg-bg-alt' if loop.index is odd else 'bg-white' }}">
        <td class="p-1 font-semibold">{{ r.period }}</td>
        <td class="p-1 text-right text-green-700">{{ r.up_7d }}</td>
        <td class="p-1 text-right text-risk-red">{{ r.down_7d }}</td>
        <td class="p-1 text-right text-green-700">{{ r.up_30d }}</td>
        <td class="p-1 text-right text-risk-red">{{ r.down_30d }}</td>
        <td class="p-1 text-center">
          {% if r.net_direction == 'up' %}<span style="color:#16A34A;font-weight:700">&#9650;</span>
          {% elif r.net_direction == 'down' %}<span style="color:#DC2626;font-weight:700">&#9660;</span>
          {% else %}<span class="text-gray-400">&mdash;</span>{% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}

  {# Price Target Range Card #}
  {% set at = mkt.get('analyst_targets', {}) %}
  {% if at %}
  <div class="border border-gray-200 rounded-lg p-3 my-3 page-break-inside-avoid">
    <div class="text-xs font-semibold text-gray-600 uppercase tracking-wider mb-2">Analyst Price Target Range</div>
    {# Horizontal bar from low to high with current price marker #}
    {% if at.low != 'N/A' and at.high != 'N/A' %}
    <div class="relative my-3" style="height:32px">
      <div class="absolute inset-x-0 top-1/2 -translate-y-1/2 h-3 bg-gray-200 rounded-full"></div>
      {# Mean target marker #}
      {% if at.mean != 'N/A' %}
      <div class="absolute top-1/2 -translate-y-1/2 w-3 h-3 bg-blue-600 rounded-full border-2 border-white" style="left:50%" title="Mean target: {{ at.mean }}"></div>
      {% endif %}
    </div>
    {% endif %}
    <div class="flex justify-between text-xs mt-1">
      <div>
        <div class="text-gray-500">Low</div>
        <div class="font-semibold">{{ at.low }}</div>
      </div>
      <div class="text-center">
        <div class="text-gray-500">Mean Target</div>
        <div class="font-semibold text-blue-700">{{ at.mean }}</div>
      </div>
      <div class="text-right">
        <div class="text-gray-500">High</div>
        <div class="font-semibold">{{ at.high }}</div>
      </div>
    </div>
    <div class="flex justify-between items-center mt-2 pt-2 border-t border-gray-100 text-xs">
      <span class="text-gray-500">Current: <strong>{{ at.current }}</strong></span>
      {% if at.upside_pct != 'N/A' %}
      <span class="px-2 py-0.5 rounded font-semibold {{ 'bg-green-100 text-green-800' if at.upside_pct and at.upside_pct.startswith('+') else 'bg-red-100 text-red-800' }}">
        Implied {{ at.upside_pct }}
      </span>
      {% endif %}
      {% if at.analyst_count %}
      <span class="text-gray-400">{{ at.analyst_count }} analysts</span>
      {% endif %}
    </div>
  </div>
  {% endif %}
{% endif %}
