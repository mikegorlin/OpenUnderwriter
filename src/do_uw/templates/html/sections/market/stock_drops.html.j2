{# Significant Stock Drops — extracted from market.html.j2 #}
  {# --- Significant Stock Drops --- #}
  {% set drop_events = mkt.get('drop_events', []) %}
  {% if drop_events or mkt.get('worst_drop_pct') %}
  <h3>Significant Stock Drops</h3>
  {% if mkt.get('worst_drop_pct') %}
  <div class="border-l-4 border-red-600 bg-red-50 pl-3 py-2 my-3 page-break-inside-avoid">
    <p class="text-sm font-semibold text-red-800 m-0">
      Worst single-day decline: {{ mkt.worst_drop_pct }}
      {% if mkt.get('worst_drop_date') %} on {{ mkt.worst_drop_date }}{% endif %}
      {{ mkt.get('worst_drop_trigger', '') }}
    </p>
  </div>
  {% endif %}

  {# --- DDL Exposure (Phase 89) --- #}
  {% if mkt.get('ddl_exposure') %}
  <div class="bg-amber-50 border border-amber-200 rounded p-3 my-3 page-break-inside-avoid">
    <p class="text-sm m-0">
      <strong>Observed DDL Exposure:</strong> {{ mkt.ddl_exposure }}
      {% if mkt.get('ddl_settlement_estimate') %}
        &nbsp;&bull;&nbsp; <strong>Est. Settlement (1.8%):</strong> {{ mkt.ddl_settlement_estimate }}
      {% endif %}
      {% if mkt.get('mdl_exposure') %}
        &nbsp;&bull;&nbsp; <strong>MDL Exposure:</strong> {{ mkt.mdl_exposure }}
      {% endif %}
    </p>
    <p class="text-xs text-gray-500 m-0 mt-1">Based on actual worst observed drop &times; market cap. Settlement estimate uses historical 1.8% DDL-to-settlement ratio.</p>
    {# Fix 5: DDL context — theoretical max vs expected loss for underwriter clarity #}
    <p class="text-xs text-gray-400 m-0 mt-1" style="font-style:italic">
      Note: DDL (Dollar Damage Line) is the theoretical maximum exposure if 100% of damaged shares were in the plaintiff class.
      {% if mkt.get('ddl_settlement_estimate') %}The estimated settlement ({{ mkt.ddl_settlement_estimate }}) is the actuarially relevant figure for underwriting — actual settlements historically run 1.5-5% of DDL.{% endif %}
    </p>
  </div>
  {% endif %}

  {% if drop_events %}
  {# Check if any drops have AR data #}
  {% set has_ar = drop_events | selectattr('abnormal_return', 'ne', '') | list | length > 0 %}
  {# Check if any drops have decomposition data (Phase 90) #}
  {% set has_decomp = drop_events | selectattr('market_pct', 'ne', 'N/A') | list | length > 0 %}
  {# Check if any drops have disclosure data (Phase 90) #}
  {% set has_disclosure = drop_events | selectattr('disclosure_badge', 'ne', '') | list | length > 0 %}
  {% set has_prices = drop_events | selectattr('from_price', 'ne', 'N/A') | list | length > 0 %}
  <table class="w-full border-collapse my-3 text-sm">
    <thead>
      <tr class="bg-navy text-white">
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-left p-1">Date</th>
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right p-1">Drop</th>
        {% if has_prices %}
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right px-2 py-2">From</th>
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right px-2 py-2">To</th>
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right px-2 py-2">Volume</th>
        {% endif %}
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right px-2 py-2">Recency</th>
        {% if has_ar %}
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right px-2 py-2">AR</th>
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right px-2 py-2">t-stat</th>
        {% endif %}
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-center px-2 py-2">Type</th>
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-left p-1">Trigger</th>
        {% if has_decomp %}
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right px-2 py-2">Market</th>
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right px-2 py-2">Sector</th>
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right px-2 py-2">Company</th>
        {% endif %}
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right p-1">Recovery</th>
        {% if has_disclosure %}
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-center px-2 py-2">Disclosure</th>
        {% endif %}
      </tr>
    </thead>
    <tbody class="tabular-nums">
      {% for evt in drop_events %}
      {% set row_bg = 'bg-red-50' if evt.severity_class == 'critical' else 'bg-amber-50' if evt.severity_class == 'high' else ('bg-bg-alt' if loop.index is odd else 'bg-white') %}
      <tr class="{{ row_bg }}">
        <td class="p-1 font-semibold whitespace-nowrap">{{ evt.date }}</td>
        <td class="p-1 text-right font-semibold {{ 'text-red-700' if evt.severity_class == 'critical' else 'text-amber-700' if evt.severity_class == 'high' else 'text-risk-red' }}">-{{ evt.drop_pct }}</td>
        {% if has_prices %}
        <td class="px-2 py-2 text-right text-xs tabular-nums">{{ evt.from_price }}</td>
        <td class="px-2 py-2 text-right text-xs tabular-nums">{{ evt.to_price }}</td>
        <td class="px-2 py-2 text-right text-xs tabular-nums">{{ evt.volume }}</td>
        {% endif %}
        <td class="px-2 py-2 text-right text-xs">{{ evt.decay_weight }}</td>
        {% if has_ar %}
        <td class="px-2 py-2 text-right text-xs {{ 'font-semibold' if evt.significant }}">
          {{ evt.abnormal_return }}{{ evt.significant }}
        </td>
        <td class="px-2 py-2 text-right text-xs {{ 'text-risk-red font-semibold' if evt.significant }}">
          {{ evt.t_stat }}
        </td>
        {% endif %}
        <td class="px-2 py-2 text-center text-xs">
          {{ evt.type | replace('_', ' ') }}
          {% if evt.days != '1' %}<span class="text-gray-400">({{ evt.days }}d)</span>{% endif %}
        </td>
        <td class="p-1 text-xs">
          <div>
            <span style="font-weight:600">{{ evt.trigger }}</span>
            {% if evt.is_market_wide == 'Yes' %}<span class="ml-1 px-1 py-0.5 bg-blue-100 text-blue-800 text-xs rounded">Market-Wide</span>{% endif %}
            {% if evt.trigger_description and 'Find the latest' not in evt.trigger_description and 'stock quote' not in evt.trigger_description and 'vital information' not in evt.trigger_description %}
            <div class="mt-1 text-xs text-gray-600 leading-snug max-w-xs">{{ evt.trigger_description }}</div>
            {% endif %}
          </div>
        </td>
        {% if has_decomp %}
        <td class="px-2 py-2 text-right text-xs">{{ evt.market_pct }}</td>
        <td class="px-2 py-2 text-right text-xs">{{ evt.sector_pct }}</td>
        <td class="px-2 py-2 text-right text-xs">
          {{ evt.company_pct }}
          {% if evt.market_driven %}<span class="ml-1 px-1 py-0.5 bg-blue-100 text-blue-800 text-xs rounded">{{ evt.market_driven }}</span>{% endif %}
        </td>
        {% endif %}
        <td class="p-1 text-right">{{ evt.recovery }}</td>
        {% if has_disclosure %}
        <td class="px-2 py-2 text-center text-xs">
          {% if evt.disclosure_badge %}<span class="px-1 py-0.5 bg-green-100 text-green-800 rounded">{{ evt.disclosure_badge }}</span>{% endif %}
        </td>
        {% endif %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {# --- Phase 133: Significant Decline Event Cards (>=10% drops) --- #}
  {% set major_drops = drop_events | selectattr('severity_class', 'in', ['critical', 'high']) | list %}
  {% if major_drops %}
  <h4 class="mt-4 mb-2 font-semibold text-sm">Significant Decline Events</h4>
  <div class="space-y-3">
    {% for evt in major_drops %}
    <div class="border border-gray-200 rounded-lg p-3 page-break-inside-avoid {{ 'bg-red-50 border-red-300' if evt.severity_class == 'critical' else 'bg-amber-50 border-amber-300' }}">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-xs font-semibold text-white px-2 py-0.5 rounded {{ 'bg-red-700' if evt.severity_class == 'critical' else 'bg-amber-600' }}">-{{ evt.drop_pct }}</span>
        <span class="text-sm font-semibold">{{ evt.date }}</span>
        <span class="text-xs text-gray-600">{{ evt.trigger }}</span>
        {% if evt.recovery != 'N/A' %}<span class="text-xs text-gray-500">Recovery: {{ evt.recovery }}</span>{% endif %}
      </div>

      {# Attribution bar #}
      {% set attr = evt.get('attribution_split', {}) %}
      {% if attr and (attr.market_pct or attr.sector_pct or attr.company_pct) %}
      {% set total = (attr.market_pct|abs + attr.sector_pct|abs + attr.company_pct|abs) or 1 %}
      <div class="flex items-center gap-2 mb-2">
        <span class="text-xs text-gray-500 w-16">Attribution:</span>
        <div class="flex-1 h-4 rounded overflow-hidden flex" style="max-width:300px">
          <div class="bg-gray-400 h-full" style="width:{{ (attr.market_pct|abs / total * 100)|round }}%" title="Market: {{ evt.market_pct }}"></div>
          <div class="bg-blue-500 h-full" style="width:{{ (attr.sector_pct|abs / total * 100)|round }}%" title="Sector: {{ evt.sector_pct }}"></div>
          <div class="bg-red-600 h-full" style="width:{{ (attr.company_pct|abs / total * 100)|round }}%" title="Company: {{ evt.company_pct }}"></div>
        </div>
        <div class="text-xs text-gray-500 flex gap-2">
          <span><span class="inline-block w-2 h-2 bg-gray-400 rounded-sm"></span> Mkt {{ evt.market_pct }}</span>
          <span><span class="inline-block w-2 h-2 bg-blue-500 rounded-sm"></span> Sect {{ evt.sector_pct }}</span>
          <span><span class="inline-block w-2 h-2 bg-red-600 rounded-sm"></span> Co {{ evt.company_pct }}</span>
        </div>
      </div>
      {% endif %}

      {# D&O Theory #}
      {% if evt.get('do_theory') %}
      <p class="text-xs text-gray-700 m-0 italic">{{ evt.do_theory }}</p>
      {% endif %}

      {# Multi-day breakdown #}
      {% if evt.get('is_multi_day') and evt.get('consolidated_days') and evt.consolidated_days|length > 1 %}
      <details class="mt-2">
        <summary class="text-xs text-gray-500 cursor-pointer">Per-day breakdown ({{ evt.consolidated_days|length }} days)</summary>
        <div class="flex gap-2 flex-wrap mt-1">
          {% for d in evt.consolidated_days %}
          <span class="text-xs px-1 py-0.5 bg-white rounded border border-gray-200">{{ d.date }}: {{ '%.1f'|format(d.pct) }}%</span>
          {% endfor %}
        </div>
      </details>
      {% endif %}
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% set overflow_drops = mkt.get('drop_events_overflow', []) %}
  {% if overflow_drops|length > drop_events|length %}
  <p class="text-xs text-gray-400 mt-1">Showing top {{ drop_events|length }} drops from past 12 months. <a href="#audit-market-overflow" class="text-blue-600 hover:underline">See all {{ overflow_drops|length }} historical drops in Audit Trail</a>.</p>
  {% endif %}
  <p class="text-xs text-gray-500 mt-1">
    Sorted by recency-weighted severity. Recency = time-decay weight (100% = today, 50% = 180d ago).
    {% if has_ar %}AR = Abnormal Return (market model). ** = statistically significant at 95% (|t| &ge; 1.96).{% endif %}
    {% if has_decomp %}Market/Sector/Company = return decomposition attribution.{% endif %}
    {% if has_disclosure %}Disclosure = corrective filing or article found after drop.{% endif %}
  </p>
  {% endif %}
  {% endif %}
