{# Stock Performance Summary — Phase 119 (STOCK-04, STOCK-06) #}
{# Multi-horizon returns table + analyst consensus + interpretive narrative. #}

{% if has_performance_data %}
<div class="page-break-inside-avoid mt-4">
  <h3 class="font-heading text-base font-semibold text-navy mb-2">Stock Performance Summary</h3>

  {# Multi-horizon returns #}
  {% if horizons %}
  <table class="data-table w-full border-collapse text-sm mb-3">
    <thead>
      <tr class="bg-navy text-white">
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-left p-1">Horizon</th>
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right p-1">Return</th>
      </tr>
    </thead>
    <tbody class="tabular-nums">
      {% for h in horizons %}
      <tr class="{{ 'bg-bg-alt' if loop.index is odd else 'bg-white' }}">
        <td class="p-1 font-semibold">{{ h.label }}</td>
        <td class="p-1 text-right {{ 'text-risk-red' if h.return_pct.startswith('-') else 'text-green-700' if h.return_pct.startswith('+') else '' }}">{{ h.return_pct }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}

  {# Analyst Consensus #}
  {% if analyst %}
  <h4 class="font-heading text-sm font-semibold uppercase tracking-wider text-navy mb-2">Analyst Consensus</h4>

  {# Rating distribution bar chart #}
  {% if analyst.rating_distribution %}
  {% set rd = analyst.rating_distribution %}
  {% set total_ratings = rd.get('strongBuy', 0) + rd.get('buy', 0) + rd.get('hold', 0) + rd.get('sell', 0) + rd.get('strongSell', 0) %}
  {% if total_ratings > 0 %}
  <div class="flex items-center gap-1 mb-2 h-6 rounded overflow-hidden text-xs font-semibold text-white">
    {% if rd.get('strongBuy', 0) > 0 %}
    <div class="bg-green-700 flex items-center justify-center h-full" style="width: {{ (rd.strongBuy / total_ratings * 100) | round(1) }}%">{{ rd.strongBuy }}</div>
    {% endif %}
    {% if rd.get('buy', 0) > 0 %}
    <div class="bg-green-500 flex items-center justify-center h-full" style="width: {{ (rd.buy / total_ratings * 100) | round(1) }}%">{{ rd.buy }}</div>
    {% endif %}
    {% if rd.get('hold', 0) > 0 %}
    <div class="bg-amber-500 flex items-center justify-center h-full" style="width: {{ (rd.hold / total_ratings * 100) | round(1) }}%">{{ rd.hold }}</div>
    {% endif %}
    {% if rd.get('sell', 0) > 0 %}
    <div class="bg-red-500 flex items-center justify-center h-full" style="width: {{ (rd.sell / total_ratings * 100) | round(1) }}%">{{ rd.sell }}</div>
    {% endif %}
    {% if rd.get('strongSell', 0) > 0 %}
    <div class="bg-red-700 flex items-center justify-center h-full" style="width: {{ (rd.strongSell / total_ratings * 100) | round(1) }}%">{{ rd.strongSell }}</div>
    {% endif %}
  </div>
  <p class="text-xs text-gray-500 mb-2">Strong Buy: {{ rd.get('strongBuy', 0) }} | Buy: {{ rd.get('buy', 0) }} | Hold: {{ rd.get('hold', 0) }} | Sell: {{ rd.get('sell', 0) }} | Strong Sell: {{ rd.get('strongSell', 0) }}</p>
  {% endif %}
  {% endif %}

  {# Target prices table #}
  <table class="data-table w-full border-collapse text-sm mb-3">
    <tbody class="tabular-nums">
      {% if analyst.get('consensus_label') %}
      <tr class="bg-bg-alt">
        <td class="p-1 font-semibold w-1/3">Consensus</td>
        <td class="p-1">{{ analyst.consensus_label }}</td>
      </tr>
      {% endif %}
      {% if analyst.get('mean_target') %}
      <tr>
        <td class="p-1 font-semibold">Mean Target</td>
        <td class="p-1">${{ "%.2f" | format(analyst.mean_target) }}</td>
      </tr>
      {% endif %}
      {% if analyst.get('high_target') %}
      <tr class="bg-bg-alt">
        <td class="p-1 font-semibold">High Target</td>
        <td class="p-1">${{ "%.2f" | format(analyst.high_target) }}</td>
      </tr>
      {% endif %}
      {% if analyst.get('low_target') %}
      <tr>
        <td class="p-1 font-semibold">Low Target</td>
        <td class="p-1">${{ "%.2f" | format(analyst.low_target) }}</td>
      </tr>
      {% endif %}
      {% if analyst.get('upside_pct') is not none %}
      <tr class="bg-bg-alt">
        <td class="p-1 font-semibold">Upside/Downside</td>
        <td class="p-1 {{ 'text-green-700' if analyst.upside_pct >= 0 else 'text-risk-red' }}">{{ "%+.1f" | format(analyst.upside_pct) }}%</td>
      </tr>
      {% endif %}
      {% if analyst.get('coverage_count') %}
      <tr>
        <td class="p-1 font-semibold">Coverage Count</td>
        <td class="p-1">{{ analyst.coverage_count }} analysts</td>
      </tr>
      {% endif %}
    </tbody>
  </table>

  {# Interpretive narrative (STOCK-06) #}
  {% if analyst.get('narrative') %}
  <p class="text-sm text-gray-700 leading-relaxed">{{ analyst.narrative }}</p>
  {% endif %}
  {% endif %}
</div>
{% endif %}
