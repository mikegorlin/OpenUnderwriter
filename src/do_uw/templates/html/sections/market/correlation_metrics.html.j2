{# Correlation Metrics — return correlation vs SPY/sector, R-squared, idiosyncratic risk.
   Data from mkt.correlation_metrics (built by build_correlation_metrics).
   Phase 133-02: STOCK-08. #}

{% set cm = mkt.get('correlation_metrics', {}) %}
{% if cm %}
  <h3>Return Correlation Analysis</h3>

  {# 2x2 metric grid #}
  <div class="grid grid-cols-2 gap-3 my-3">
    {# Correlation vs SPY #}
    <div class="border border-gray-200 rounded-lg p-3 text-center page-break-inside-avoid">
      <div class="text-xs text-gray-500 uppercase tracking-wider mb-1">Corr. vs SPY</div>
      <div class="text-xl font-semibold tabular-nums">{{ cm.corr_spy }}</div>
      {% if cm.corr_spy != 'N/A' %}
      <div class="text-xs text-gray-500 mt-1">
        {% set cv = cm.corr_spy|float(0) %}
        {{ 'High' if cv > 0.7 else 'Medium' if cv > 0.4 else 'Low' }} market correlation
      </div>
      {% endif %}
    </div>

    {# Correlation vs Sector ETF #}
    <div class="border border-gray-200 rounded-lg p-3 text-center page-break-inside-avoid">
      <div class="text-xs text-gray-500 uppercase tracking-wider mb-1">Corr. vs Sector ETF</div>
      <div class="text-xl font-semibold tabular-nums">{{ cm.corr_sector }}</div>
      {% if cm.corr_sector != 'N/A' %}
      <div class="text-xs text-gray-500 mt-1">
        {% set sv = cm.corr_sector|float(0) %}
        {{ 'High' if sv > 0.7 else 'Medium' if sv > 0.4 else 'Low' }} sector alignment
      </div>
      {% endif %}
    </div>

    {# R-squared #}
    <div class="border border-gray-200 rounded-lg p-3 text-center page-break-inside-avoid">
      <div class="text-xs text-gray-500 uppercase tracking-wider mb-1">R-Squared</div>
      <div class="text-xl font-semibold tabular-nums">{{ cm.r_squared }}</div>
      {% if cm.r_squared != 'N/A' %}
      <div class="text-xs text-gray-500 mt-1">{{ '%.0f'|format(cm.r_squared|float(0) * 100) }}% of variance explained by market</div>
      {% endif %}
    </div>

    {# Idiosyncratic Risk #}
    <div class="border border-gray-200 rounded-lg p-3 text-center page-break-inside-avoid">
      <div class="text-xs text-gray-500 uppercase tracking-wider mb-1">Idiosyncratic Risk</div>
      <div class="text-xl font-semibold tabular-nums">{{ cm.idiosyncratic_pct }}</div>
      {% if cm.idiosyncratic_pct != 'N/A' %}
      {% set iv = cm.idiosyncratic_pct|replace('%', '')|float(0) %}
      <div class="mt-1">
        <span class="text-xs font-semibold px-2 py-0.5 rounded {{ 'bg-red-100 text-red-800' if iv > 70 else 'bg-amber-100 text-amber-800' if iv > 40 else 'bg-green-100 text-green-800' }}">
          {{ 'High' if iv > 70 else 'Medium' if iv > 40 else 'Low' }}
        </span>
      </div>
      {% endif %}
    </div>
  </div>

  {# Beta #}
  {% if cm.beta != 'N/A' %}
  <div class="text-xs text-gray-600 mb-2">
    <strong>Beta:</strong> {{ cm.beta }}
    ({{ '> market sensitivity' if cm.beta|float(0) > 1.2 else '< market sensitivity' if cm.beta|float(0) < 0.8 else 'market-like sensitivity' }})
  </div>
  {% endif %}

  {# D&O Interpretation #}
  {% if cm.interpretation %}
  <div class="border-l-4 border-blue-600 bg-blue-50 pl-3 py-2 my-3 page-break-inside-avoid">
    <p class="text-xs font-semibold text-blue-800 mb-1">D&O Loss Causation Implications</p>
    <p class="text-xs text-gray-700 m-0">{{ cm.interpretation }}</p>
  </div>
  {% endif %}

  <p class="text-xs text-gray-500 mt-1">
    Correlation computed from 1-year daily returns. R-squared = fraction of company return variance explained by market.
    Idiosyncratic risk = company-specific return component. Higher idiosyncratic risk means losses are more attributable to company actions vs market forces.
  </p>
{% endif %}
