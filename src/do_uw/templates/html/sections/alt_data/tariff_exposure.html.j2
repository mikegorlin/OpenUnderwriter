{# Tariff / Trade Exposure — Phase 119 (ALTDATA-03) #}
{# Renders supply chain exposure, manufacturing locations, risk factors, D&O relevance. #}

{% if has_tariff_data %}
<div class="page-break-inside-avoid mt-4">
  <h4 class="font-heading text-sm font-semibold uppercase tracking-wider text-navy mb-2">Tariff / Trade Exposure</h4>

  <table class="data-table w-full border-collapse text-sm mb-3">
    <tbody>
      <tr class="bg-bg-alt">
        <td class="p-1 font-semibold w-1/4">Risk Level</td>
        <td class="p-1 {{ 'text-risk-red font-semibold' if tariff_risk_level == 'HIGH' else 'text-amber-600 font-semibold' if tariff_risk_level == 'MEDIUM' else '' }}">{{ tariff_risk_level }}</td>
      </tr>
      <tr>
        <td class="p-1 font-semibold">Supply Chain Exposure</td>
        <td class="p-1 text-xs">{{ tariff_supply_chain }}</td>
      </tr>
      {% if tariff_manufacturing %}
      <tr class="bg-bg-alt">
        <td class="p-1 font-semibold align-top">Manufacturing Locations</td>
        <td class="p-1 text-xs">
          {% for loc in tariff_manufacturing %}{{ loc }}{% if not loop.last %}, {% endif %}{% endfor %}
        </td>
      </tr>
      {% endif %}
      <tr>
        <td class="p-1 font-semibold">Int'l Revenue %</td>
        <td class="p-1">{{ tariff_intl_revenue }}</td>
      </tr>
      {% if tariff_factors %}
      <tr class="bg-bg-alt">
        <td class="p-1 font-semibold align-top">Risk Factors</td>
        <td class="p-1 text-xs">
          <ul class="list-disc list-inside m-0 p-0">
            {% for f in tariff_factors %}
            <li>{{ f }}</li>
            {% endfor %}
          </ul>
        </td>
      </tr>
      {% endif %}
    </tbody>
  </table>

  {% if tariff_do_relevance %}
  <div class="border-l-4 border-amber-500 bg-amber-50 pl-3 py-2">
    <p class="text-sm do-callout m-0"><strong>D&O Relevance:</strong> {{ tariff_do_relevance }}</p>
  </div>
  {% endif %}
</div>
{% endif %}
