{# Filing Analysis -- Filing Patterns & Whistleblower facet template.
   Renders NLP.FILING + NLP.DISCLOSURE + NLP.CAM + NLP.WHISTLE signals.
   Late filing alerts, timing changes, hedging language, CAM changes,
   whistleblower language. Metric table format.
   Part of facet dispatch for filing_analysis section. #}

{% set nlp = nlp_signals or {} %}
<div class="facet-block" id="facet-filing_patterns">
  <h3>Filing Patterns & Whistleblower</h3>
  {% if nlp %}
    <table class="w-full border-collapse text-sm my-3">
      <thead>
        <tr class="bg-gray-100">
          <th class="text-left p-1 border-b font-heading text-xs font-semibold uppercase">Indicator</th>
          <th class="text-left p-1 border-b font-heading text-xs font-semibold uppercase">Assessment</th>
        </tr>
      </thead>
      <tbody>
        <tr class="{{ 'bg-red-50' if nlp.late_filing else 'bg-white' }}">
          <td class="p-1 font-semibold">Late Filing</td>
          <td class="p-1">
            {% if nlp.late_filing %}
              <span class="text-risk-red font-semibold">{{ nlp.late_filing }}</span>
            {% else %}
              N/A
            {% endif %}
          </td>
        </tr>
        <tr class="bg-bg-alt">
          <td class="p-1 font-semibold">Filing Timing Change</td>
          <td class="p-1">{{ nlp.filing_timing_change | default('—') }}</td>
        </tr>
        <tr class="bg-white">
          <td class="p-1 font-semibold">Forward-Looking Decrease</td>
          <td class="p-1">{{ nlp.forward_looking_decrease | default('—') }}</td>
        </tr>
        <tr class="bg-bg-alt">
          <td class="p-1 font-semibold">Hedging Language Increase</td>
          <td class="p-1">{{ nlp.hedging_language_increase | default('—') }}</td>
        </tr>
        <tr class="bg-white">
          <td class="p-1 font-semibold">CAM Changes</td>
          <td class="p-1">{{ nlp.cam_changes | default('—') }}</td>
        </tr>
        <tr class="{{ 'bg-red-50' if nlp.internal_investigation else 'bg-bg-alt' }}">
          <td class="p-1 font-semibold">Internal Investigation</td>
          <td class="p-1">
            {% if nlp.internal_investigation %}
              <span class="text-risk-red font-semibold">{{ nlp.internal_investigation }}</span>
            {% else %}
              N/A
            {% endif %}
          </td>
        </tr>
        <tr class="{{ 'bg-red-50' if nlp.whistleblower_language else 'bg-white' }}">
          <td class="p-1 font-semibold">Whistleblower Language</td>
          <td class="p-1">
            {% if nlp.whistleblower_language %}
              <span class="text-risk-red font-semibold">{{ nlp.whistleblower_language }}</span>
            {% else %}
              N/A
            {% endif %}
          </td>
        </tr>
      </tbody>
    </table>
  {% else %}
    <p class="text-sm text-gray-500">NLP analysis data not available.</p>
  {% endif %}
</div>
