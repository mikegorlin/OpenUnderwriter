{# Filing Analysis -- Risk Factor Analysis facet template.
   Renders NLP.RISK signals: risk factor count change, new risk factors,
   new litigation/regulatory risk factors.
   Metric table with red highlighting for new risk factors.
   Part of facet dispatch for filing_analysis section. #}

{% set nlp = nlp_signals or {} %}
<div class="facet-block" id="facet-risk_factor_analysis">
  <h3>Risk Factor Analysis</h3>
  {% if nlp %}
    <table class="w-full border-collapse text-sm my-3">
      <thead>
        <tr class="bg-gray-100">
          <th class="text-left p-1 border-b font-heading text-xs font-semibold uppercase">Indicator</th>
          <th class="text-left p-1 border-b font-heading text-xs font-semibold uppercase">Assessment</th>
        </tr>
      </thead>
      <tbody>
        <tr class="{{ 'bg-red-50' if nlp.risk_factor_count_change and nlp.risk_factor_count_change != 'N/A' and nlp.risk_factor_count_change != 'None' else 'bg-white' }}">
          <td class="p-1 font-semibold">Risk Factor Count Change</td>
          <td class="p-1">{{ nlp.risk_factor_count_change | default('—') }}</td>
        </tr>
        <tr class="{{ 'bg-red-50' if nlp.new_risk_factors else 'bg-bg-alt' }}">
          <td class="p-1 font-semibold">New Risk Factors</td>
          <td class="p-1">
            {% if nlp.new_risk_factors %}
              <span class="text-risk-red font-semibold">{{ nlp.new_risk_factors }}</span>
            {% else %}
              N/A
            {% endif %}
          </td>
        </tr>
        <tr class="{{ 'bg-red-50' if nlp.litigation_risk_factor_new else 'bg-white' }}">
          <td class="p-1 font-semibold">New Litigation Risk Factor</td>
          <td class="p-1">
            {% if nlp.litigation_risk_factor_new %}
              <span class="text-risk-red font-semibold">{{ nlp.litigation_risk_factor_new }}</span>
            {% else %}
              N/A
            {% endif %}
          </td>
        </tr>
        <tr class="{{ 'bg-red-50' if nlp.regulatory_risk_factor_new else 'bg-bg-alt' }}">
          <td class="p-1 font-semibold">New Regulatory Risk Factor</td>
          <td class="p-1">
            {% if nlp.regulatory_risk_factor_new %}
              <span class="text-risk-red font-semibold">{{ nlp.regulatory_risk_factor_new }}</span>
            {% else %}
              N/A
            {% endif %}
          </td>
        </tr>
      </tbody>
    </table>
  {% else %}
    <p class="text-sm text-gray-500">NLP analysis data not available.</p>
  {% endif %}
</div>
