{# Governance Score Breakdown — visual bar chart of governance dimension scores #}

{% set score_breakdown = gov.get('score_breakdown', []) %}
{% set gov_score = gov.get('governance_score') %}
{% if score_breakdown %}
<h3>Governance Score Breakdown</h3>

{# Overall score badge #}
{% if gov_score %}
<div style="display: flex; align-items: center; gap: 12px; margin: 8px 0 16px 0;">
  <span style="font-size: 10px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">Overall Score</span>
  {% set score_num = gov_score|replace('/100', '')|float(default=0) %}
  <span style="font-size: 20px; font-weight: 700; color: {{ '#16a34a' if score_num >= 75 else '#d97706' if score_num >= 50 else '#dc2626' }};">{{ gov_score }}</span>
  <div style="flex: 1; height: 10px; background: #e2e8f0; border-radius: 5px; overflow: hidden; max-width: 200px;">
    <div style="height: 100%; width: {{ score_num|int }}%; background: {{ '#16a34a' if score_num >= 75 else '#d97706' if score_num >= 50 else '#dc2626' }}; border-radius: 5px;"></div>
  </div>
</div>
{% endif %}

{# Dimension breakdown bars #}
<div style="margin: 8px 0 16px 0;">
  {% for dim in score_breakdown %}
  <div style="display: flex; align-items: center; gap: 8px; margin: 4px 0; height: 22px;">
    <span style="width: 90px; font-size: 10px; font-weight: 600; color: #1e3a5f; text-align: right; flex-shrink: 0;">{{ dim.label }}</span>
    <div style="flex: 1; height: 14px; background: #f1f5f9; border-radius: 3px; overflow: hidden; position: relative;">
      {% set score_val = dim.score|float(default=0) %}
      {% set max_val = dim.max|float(default=10) %}
      <div style="height: 100%; width: {{ dim.pct }}%; background: {{ '#16a34a' if score_val >= max_val * 0.75 else '#d97706' if score_val >= max_val * 0.5 else '#dc2626' }}; border-radius: 3px; transition: width 0.3s;"></div>
    </div>
    <span style="width: 50px; font-size: 11px; font-weight: 600; color: #374151; font-variant-numeric: tabular-nums; flex-shrink: 0;">{{ dim.score }}/{{ dim.max }}</span>
  </div>
  {% endfor %}
</div>
{% endif %}
