{# Officer Background Investigation -- Phase 135 GOV-01, GOV-02 #}

  {% if gov.get('has_officer_backgrounds') %}
  <h3>Officer Background Investigation</h3>
  <p class="text-xs text-gray-500 mb-2">
    {{ gov.get('officer_backgrounds', [])|length }} officer{{ 's' if gov.get('officer_backgrounds', [])|length != 1 else '' }} investigated,
    {{ gov.get('serial_defendant_count', 0) }} serial defendant{{ 's' if gov.get('serial_defendant_count', 0) != 1 else '' }} identified
  </p>

  {% for officer in gov.get('officer_backgrounds', []) %}
  <div style="border: 1px solid #e2e8f0; border-radius: 6px; padding: 10px 12px; margin-bottom: 10px; background: white;">
    {# Officer header: name + title + badges #}
    <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
      <span style="font-weight: 700; font-size: 13px; color: #1e3a5f;">{{ officer.name }}</span>
      <span style="font-size: 11px; color: #64748b;">{{ officer.title }}</span>
      {% if officer.is_serial_defendant %}
      <span style="background: #DC2626; color: white; font-size: 9px; font-weight: 700; padding: 2px 6px; border-radius: 3px; text-transform: uppercase; letter-spacing: 0.05em;">Serial Defendant</span>
      {% endif %}
      {# Suitability badge #}
      {% set suit_colors = {'HIGH': '#16A34A', 'MEDIUM': '#D97706', 'LOW': '#DC2626'} %}
      <span style="background: {{ suit_colors.get(officer.suitability, '#9CA3AF') }}; color: white; font-size: 9px; font-weight: 600; padding: 2px 6px; border-radius: 3px;">
        {{ officer.suitability }}
      </span>
    </div>

    {% if officer.suitability_reason %}
    <div style="font-size: 10px; color: #64748b; margin-bottom: 6px;">{{ officer.suitability_reason }}</div>
    {% endif %}

    {# Prior companies sub-table #}
    <div style="margin-bottom: 6px;">
      <div style="font-size: 10px; font-weight: 600; color: #1e3a5f; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">Prior Companies</div>
      {% if officer.prior_companies %}
      <table class="w-full border-collapse text-xs">
        <thead>
          <tr class="bg-gray-50">
            <th class="text-left p-1 font-semibold">Company</th>
            <th class="text-left p-1 font-semibold">Role</th>
            <th class="text-center p-1 font-semibold tabular-nums">Years</th>
          </tr>
        </thead>
        <tbody>
          {% for pc in officer.prior_companies %}
          <tr class="{{ 'bg-bg-alt' if loop.index is odd else 'bg-white' }}">
            <td class="p-1">{{ pc.company_name }}</td>
            <td class="p-1">{{ pc.role }}</td>
            <td class="p-1 text-center tabular-nums">{{ pc.years }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <div style="font-size: 10px; color: #9CA3AF; font-style: italic;">No prior public company history found</div>
      {% endif %}
    </div>

    {# SCA Exposure sub-table (only if serial defendant or has exposures) #}
    {% if officer.sca_exposures %}
    <div style="margin-bottom: 6px;">
      <div style="font-size: 10px; font-weight: 600; color: #DC2626; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">SCA Exposure</div>
      <table class="w-full border-collapse text-xs">
        <thead>
          <tr class="bg-red-50">
            <th class="text-left p-1 font-semibold">Case</th>
            <th class="text-left p-1 font-semibold">Company</th>
            <th class="text-left p-1 font-semibold">Class Period</th>
            <th class="text-left p-1 font-semibold">Role at Time</th>
            <th class="text-right p-1 font-semibold tabular-nums">Settlement</th>
          </tr>
        </thead>
        <tbody>
          {% for exp in officer.sca_exposures %}
          <tr class="{{ 'bg-red-50' if loop.index is odd else 'bg-white' }}">
            <td class="p-1">{{ exp.case_caption }}</td>
            <td class="p-1">{{ exp.company_name }}</td>
            <td class="p-1 tabular-nums">{{ exp.class_period }}</td>
            <td class="p-1">{{ exp.officer_role_at_time }}</td>
            <td class="p-1 text-right tabular-nums">{{ exp.settlement }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}

    {# Personal Litigation #}
    <div>
      <div style="font-size: 10px; font-weight: 600; color: #1e3a5f; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">Personal Litigation</div>
      {% if officer.personal_litigation %}
      <ul style="margin: 0; padding-left: 16px; font-size: 11px; color: #374151;">
        {% for lit in officer.personal_litigation %}
        <li style="margin-bottom: 2px;">{{ lit.value if lit.value is defined else lit }}</li>
        {% endfor %}
      </ul>
      {% else %}
      <div style="font-size: 10px; color: #9CA3AF; font-style: italic;">None found</div>
      {% endif %}
    </div>
  </div>
  {% endfor %}
  {% endif %}
