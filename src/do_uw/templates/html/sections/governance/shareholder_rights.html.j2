{# Shareholder Rights Inventory -- Phase 135 GOV-03, GOV-04 #}

  {% if gov.get('has_shareholder_rights') %}
  {% set rights = gov.get('shareholder_rights', {}) %}
  <h3>Shareholder Rights Inventory</h3>

  {# Overall defense posture badge #}
  {% set posture = rights.get('overall_defense_posture', 'N/A') %}
  {% set posture_colors = {'Strong': '#16A34A', 'Moderate': '#D97706', 'Weak': '#DC2626'} %}
  <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 10px;">
    <span style="background: {{ posture_colors.get(posture, '#9CA3AF') }}; color: white; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.05em;">
      {{ posture }} Defense Posture
    </span>
    <span style="font-size: 11px; color: #64748b;">
      {{ rights.get('protective_count', 0) }} protective, {{ rights.get('shareholder_friendly_count', 0) }} shareholder-friendly
    </span>
  </div>

  {# 8-provision checklist table #}
  <table class="w-full border-collapse my-3 text-sm">
    <thead>
      <tr class="bg-navy text-white">
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-left p-1" style="width: 20%;">Provision</th>
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-center px-2 py-2" style="width: 8%;">Status</th>
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-left p-1" style="width: 15%;">Details</th>
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-center px-2 py-2" style="width: 15%;">Defense Type</th>
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-left p-1" style="width: 42%;">D&amp;O Implication</th>
      </tr>
    </thead>
    <tbody>
      {% for prov in rights.get('provisions', []) %}
      {% set status = prov.get('status', 'N/A') %}
      {% set defense = prov.get('defense_strength', 'Neutral') %}
      <tr class="{{ 'bg-bg-alt' if loop.index is odd else 'bg-white' }}">
        <td class="p-1 font-semibold text-xs">{{ prov.provision_name }}</td>
        <td class="px-2 py-2 text-center">
          {% if status == 'Yes' and defense == 'Protective' %}
          <span style="background: #DCFCE7; color: #166534; font-size: 10px; font-weight: 600; padding: 1px 6px; border-radius: 3px;">Yes</span>
          {% elif status == 'Yes' and defense == 'Shareholder-Friendly' %}
          <span style="background: #FEE2E2; color: #991B1B; font-size: 10px; font-weight: 600; padding: 1px 6px; border-radius: 3px;">Yes</span>
          {% elif status == 'No' and defense == 'Protective' %}
          <span style="background: #DCFCE7; color: #166534; font-size: 10px; font-weight: 600; padding: 1px 6px; border-radius: 3px;">No</span>
          {% elif status == 'No' and defense == 'Shareholder-Friendly' %}
          <span style="background: #FEE2E2; color: #991B1B; font-size: 10px; font-weight: 600; padding: 1px 6px; border-radius: 3px;">No</span>
          {% elif status == 'N/A' %}
          <span style="color: #9CA3AF; font-size: 10px;">—</span>
          {% else %}
          <span style="font-size: 10px;">{{ status }}</span>
          {% endif %}
        </td>
        <td class="p-1 text-xs text-gray-600">{{ prov.get('details', '') if prov.get('details') else '&mdash;' }}</td>
        <td class="px-2 py-2 text-center">
          {% if defense == 'Protective' %}
          <span style="color: #166534; font-size: 10px; font-weight: 600;">Protective</span>
          {% elif defense == 'Shareholder-Friendly' %}
          <span style="color: #991B1B; font-size: 10px; font-weight: 600;">Shareholder-Friendly</span>
          {% else %}
          <span style="color: #64748B; font-size: 10px;">Neutral</span>
          {% endif %}
        </td>
        <td class="p-1 text-xs text-gray-700">{{ prov.do_implication }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}
