{# Short-Seller & Conviction Monitor — alert cards + conviction badge (Phase 136, FWD-04/05) #}
{% if b.short_seller_alerts or b.short_conviction %}
<div style="margin-top:10px">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
    <div style="font-size:9.5pt;font-weight:700;color:#1F3A5C">Short-Seller & Conviction Monitor</div>
    {% if b.short_conviction %}
    <span style="padding:3px 12px;border-radius:12px;font-size:8pt;font-weight:700;background:{{ b.short_conviction.conviction_color | default('#D97706') }};color:white">Bears {{ b.short_conviction.conviction | default('Stable') }}</span>
    {% endif %}
  </div>

  <div style="display:flex;gap:8px;flex-wrap:wrap">
    {# Short-seller report alert cards #}
    {% if b.short_seller_alerts and b.short_seller_alerts.alerts_available %}
    <div style="flex:1;min-width:260px">
      <div style="font-size:8pt;font-weight:700;color:#DC2626;margin-bottom:4px">Named Firm Reports Detected</div>
      {% for r in b.short_seller_alerts.reports %}
      <div style="background:white;border:1px solid #FECACA;border-left:4px solid #DC2626;border-radius:4px;padding:6px 10px;margin-bottom:4px">
        <div style="display:flex;justify-content:space-between;align-items:baseline">
          <span style="font-size:8.5pt;font-weight:700;color:#DC2626">{{ r.firm | default('Unknown Firm') }}</span>
          <span style="font-size:7pt;color:#9CA3AF">{{ r.date | default('') }}</span>
        </div>
        {% if r.title %}<div style="font-size:8pt;font-weight:600;color:#111827;margin-top:2px">{{ r.title }}</div>{% endif %}
        {% if r.summary %}<div style="font-size:7.5pt;color:#6B7280;line-height:1.35;margin-top:2px">{{ r.summary }}</div>{% endif %}
        {% if r.url %}<a href="{{ r.url }}" target="_blank" style="font-size:7pt;color:#2563EB;text-decoration:none">View Report</a>{% endif %}
      </div>
      {% endfor %}
    </div>
    {% elif b.short_seller_alerts and not b.short_seller_alerts.alerts_available %}
    <div style="flex:1;min-width:260px">
      <div style="font-size:8pt;color:#9CA3AF;padding:6px 10px;background:#F9FAFB;border-radius:4px">
        No reports from monitored firms detected.
        {% if b.short_seller_alerts.firms_checked %}
        <div style="font-size:7pt;color:#D1D5DB;margin-top:3px">Checked: {{ b.short_seller_alerts.firms_checked | join(', ') }}</div>
        {% endif %}
      </div>
    </div>
    {% endif %}

    {# Short interest conviction details #}
    {% if b.short_conviction %}
    <div style="flex:0 0 220px;background:white;border:1px solid #E5E7EB;border-radius:5px;padding:8px 10px">
      <div style="font-size:8pt;font-weight:700;color:#1F3A5C;text-transform:uppercase;letter-spacing:0.3px;margin-bottom:6px">Short Interest</div>
      {% if b.short_conviction.short_pct is not none %}
      <div style="display:flex;justify-content:space-between;padding:2px 0"><span style="font-size:7.5pt;color:#6B7280">% Float Short</span><span style="font-size:8pt;font-weight:600;color:#111827">{{ b.short_conviction.short_pct | round(2) }}%</span></div>
      {% endif %}
      {% if b.short_conviction.days_to_cover is not none %}
      <div style="display:flex;justify-content:space-between;padding:2px 0"><span style="font-size:7.5pt;color:#6B7280">Days to Cover</span><span style="font-size:8pt;font-weight:600;color:#111827">{{ b.short_conviction.days_to_cover | round(1) }}</span></div>
      {% endif %}
      {% if b.short_conviction.shares_short is not none %}
      <div style="display:flex;justify-content:space-between;padding:2px 0"><span style="font-size:7.5pt;color:#6B7280">Current Shares Short</span><span style="font-size:8pt;font-weight:600;color:#111827;font-variant-numeric:tabular-nums">{{ "{:,}".format(b.short_conviction.shares_short) }}</span></div>
      {% endif %}
      {% if b.short_conviction.pct_change is not none %}
      <div style="display:flex;justify-content:space-between;padding:2px 0;margin-top:4px;border-top:1px solid #F3F4F6;padding-top:4px">
        <span style="font-size:7.5pt;color:#6B7280">Period Change</span>
        <span style="font-size:8pt;font-weight:700;color:{{ b.short_conviction.conviction_color | default('#D97706') }}">{{ (b.short_conviction.pct_change * 100) | round(1) }}%</span>
      </div>
      {% endif %}
      {% if b.short_conviction.conviction_rationale %}
      <div style="font-size:7pt;color:#9CA3AF;line-height:1.3;margin-top:4px;border-top:1px solid #F3F4F6;padding-top:4px">{{ b.short_conviction.conviction_rationale }}</div>
      {% endif %}
    </div>
    {% endif %}
  </div>
</div>
{% endif %}
