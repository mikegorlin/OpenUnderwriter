{# Forward Risk Scenarios — cards with probability badges (Phase 136, FWD-01) #}
{% if b.forward_scenarios and b.forward_scenarios.scenarios_available %}
<div style="margin-top:10px">
  <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px">
    <div style="font-size:9.5pt;font-weight:700;color:#1F3A5C">Forward Risk Scenarios</div>
    <div style="font-size:7.5pt;color:#6B7280">
      Score: {{ b.forward_scenarios.current_score | default('N/A') }} &middot; Tier: {{ b.forward_scenarios.current_tier | default('N/A') }}
    </div>
  </div>

  <div style="display:flex;flex-wrap:wrap;gap:8px">
    {% for s in b.forward_scenarios.scenarios %}
    <div style="flex:1 1 calc(50% - 4px);min-width:280px;background:white;border:1px solid #E5E7EB;border-left:4px solid {{ s.probability_color | default('#D97706') }};border-radius:5px;padding:8px 10px;box-shadow:0 1px 2px rgba(0,0,0,0.04)">
      {# Header: name + probability badge #}
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
        <span style="font-size:9pt;font-weight:700;color:#111827">{{ s.name | default('Scenario') }}</span>
        <span style="padding:1px 8px;border-radius:10px;font-size:7pt;font-weight:700;background:{{ s.probability_color | default('#D97706') }};color:white">{{ s.probability | default('MEDIUM') }}</span>
      </div>

      {# Score impact + severity #}
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
        <div style="font-size:8pt;color:#374151">
          <span style="font-weight:600">{{ b.forward_scenarios.current_score | default('?') }}</span>
          <span style="color:#9CA3AF">&rarr;</span>
          <span style="font-weight:600">{{ s.scenario_score | default('?') }}</span>
          <span style="color:{{ s.probability_color | default('#D97706') }};font-weight:700">({{ s.score_delta | default(0) | round(1) }}{% if s.score_delta is defined and s.score_delta >= 0 %}+{% endif %})</span>
          {% if s.current_tier != s.scenario_tier %}
          <span style="padding:1px 6px;border-radius:8px;font-size:6.5pt;font-weight:700;background:#FEF2F2;color:#DC2626;margin-left:4px">{{ s.current_tier | default('') }} &rarr; {{ s.scenario_tier | default('') }}</span>
          {% endif %}
        </div>
        <span style="font-size:9pt;font-weight:700;color:#111827">{{ s.severity_estimate | default('N/A') }}</span>
      </div>

      {# Catalyst — company-specific #}
      <div style="font-size:8pt;color:#374151;line-height:1.4;margin-bottom:2px">{{ s.catalyst | default('') }}</div>

      {# Description #}
      {% if s.description %}
      <div style="font-size:7.5pt;color:#9CA3AF;line-height:1.35">{{ s.description }}</div>
      {% endif %}
    </div>
    {% endfor %}
  </div>

  <div style="font-size:7pt;color:#9CA3AF;margin-top:4px">{{ b.forward_scenarios.scenario_count }} scenarios modeled from scoring factor sensitivities</div>
</div>
{% endif %}
