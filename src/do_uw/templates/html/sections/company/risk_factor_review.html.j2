{# Risk Factor Review -- Enhanced classification with STANDARD/NOVEL/ELEVATED taxonomy #}
{# Phase 134: COMP-01, D-04 #}
{% if has_risk_factor_review %}
<h3>Risk Factor Review
  {% if risk_factor_summary %}
  <span style="font-size:8pt;font-weight:400;color:#6B7280;margin-left:8px">
    {{ risk_factor_summary.elevated }} Elevated / {{ risk_factor_summary.novel }} Novel / {{ risk_factor_summary.total }} Total
  </span>
  {% endif %}
</h3>

<table class="data-table w-full text-sm my-2">
  <thead>
    <tr>
      <th class="text-left" style="min-width:200px">Risk Factor</th>
      <th class="text-center" style="width:90px">Classification</th>
      <th class="text-center" style="width:70px">Severity</th>
      <th class="text-center" style="width:80px">YoY Delta</th>
      <th class="text-left" style="min-width:180px">D&O Implication</th>
    </tr>
  </thead>
  <tbody>
    {% for rf in risk_factor_review %}
    <tr>
      <td>
        <span class="font-medium">{{ rf.title }}</span>
        <br><span class="text-xs text-gray-500">{{ rf.category }}</span>
      </td>
      <td class="text-center">
        <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold
          {% if rf.classification == 'ELEVATED' %}bg-red-100 text-red-800
          {% elif rf.classification == 'NOVEL' %}bg-blue-100 text-blue-800
          {% else %}bg-gray-100 text-gray-600{% endif %}">
          {{ rf.classification }}
        </span>
      </td>
      <td class="text-center">
        <span class="text-xs font-semibold
          {% if rf.severity == 'HIGH' %}text-red-600
          {% elif rf.severity == 'MEDIUM' %}text-amber-600
          {% else %}text-gray-500{% endif %}">
          {{ rf.severity }}
        </span>
      </td>
      <td class="text-center">
        {% if rf.yoy_delta == 'Added' %}
        <span class="text-xs font-semibold text-blue-600">Added</span>
        {% elif rf.yoy_delta == 'Removed' %}
        <span class="text-xs line-through text-gray-400">Removed</span>
        {% elif rf.yoy_delta == 'Escalated' %}
        <span class="text-xs font-semibold text-red-600">&uarr; Escalated</span>
        {% elif rf.yoy_delta == 'Reorganized' %}
        <span class="text-xs text-purple-600">Reorganized</span>
        {% else %}
        <span class="text-xs text-gray-400">&mdash;</span>
        {% endif %}
      </td>
      <td>
        <span class="text-xs text-gray-700">{{ rf.do_implication }}</span>
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}
