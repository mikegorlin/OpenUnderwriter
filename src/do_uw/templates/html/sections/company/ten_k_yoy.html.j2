{# 10-K Year-over-Year Analysis — risk factor changes, disclosure deltas, controls #}
{# Signal-backed: DISC.YOY.new_risk_factors, DISC.YOY.removed_risk_factors, #}
{# DISC.YOY.escalated_risk_factors, DISC.YOY.material_weakness, #}
{# DISC.YOY.controls_changed, DISC.YOY.legal_proceedings_delta #}
{% if ten_k_yoy and ten_k_yoy.yoy_summary %}
{% set yoy = ten_k_yoy.yoy_summary %}
{% set sigs = ten_k_yoy.get('signal_statuses', {}) %}
<h3>10-K Year-over-Year Analysis ({{ yoy.current_year }} vs {{ yoy.prior_year }})</h3>

{# --- Summary stats bar — colors driven by signal threshold status --- #}
<div class="flex gap-4 my-2">
  {% set new_triggered = sigs.get('DISC.YOY.new_risk_factors') == 'TRIGGERED' %}
  <div class="stat-badge {{ 'bg-red-50 border-red-300' if new_triggered else 'bg-amber-50 border-amber-300' }} border px-3 py-1 rounded text-sm">
    <strong>{{ yoy.new_risks }}</strong> Truly New
  </div>
  {% set removed_triggered = sigs.get('DISC.YOY.removed_risk_factors') == 'TRIGGERED' %}
  <div class="stat-badge {{ 'bg-red-50 border-red-300' if removed_triggered else 'bg-gray-50 border-gray-300' }} border px-3 py-1 rounded text-sm">
    <strong>{{ yoy.removed_risks }}</strong> Truly Removed
  </div>
  {% if yoy.reorganized_risks is defined and yoy.reorganized_risks > 0 %}
  <div class="stat-badge bg-blue-50 border-blue-300 border px-3 py-1 rounded text-sm">
    <strong>{{ yoy.reorganized_risks }}</strong> Reorganized
  </div>
  {% endif %}
  {% set esc_triggered = sigs.get('DISC.YOY.escalated_risk_factors') == 'TRIGGERED' %}
  <div class="stat-badge {{ 'bg-red-50 border-red-300' if esc_triggered else 'bg-gray-50 border-gray-300' }} border px-3 py-1 rounded text-sm">
    <strong>{{ yoy.escalated_risks }}</strong> Escalated
  </div>
  {% if yoy.legal_delta != 0 %}
  <div class="stat-badge {{ 'bg-red-50 border-red-300' if yoy.legal_delta > 0 else 'bg-green-50 border-green-300' }} border px-3 py-1 rounded text-sm">
    <strong>{{ yoy.legal_delta|abs }}</strong> {{ 'New' if yoy.legal_delta > 0 else 'Resolved' }} Legal Proceeding{{ 's' if yoy.legal_delta|abs != 1 }}
  </div>
  {% endif %}
</div>

{# Note about high change counts (LLM extraction may over-classify) #}
{% if yoy.new_risks > 10 or yoy.removed_risks > 10 %}
<p style="font-size:0.6875rem; color:#92400e; font-style:italic; margin:0.25rem 0;">
  Note: High number of risk factor changes may reflect reorganization of disclosure language rather than new risks.
  Focus on ESCALATED items and HIGH-severity new factors below.
</p>
{% endif %}

{# --- Controls status change callout --- #}
{% if ten_k_yoy.controls_change %}
<div class="border-l-4 {{ 'border-red-600 bg-red-50' if 'APPEARED' in (ten_k_yoy.controls_change) else 'border-green-600 bg-green-50' }} p-3 my-3 rounded-r">
  <p class="text-sm font-semibold m-0">Internal Controls Change</p>
  <p class="text-sm m-0 mt-1">{{ ten_k_yoy.controls_change }}</p>
</div>
{% endif %}

{# --- Risk factor changes table (prioritized: ESCALATED + HIGH NEW first) --- #}
{% if ten_k_yoy.risk_changes %}
{# Split into priority (escalated + high-severity new) vs routine #}
{% set priority_changes = [] %}
{% set routine_changes = [] %}
{% for rc in ten_k_yoy.risk_changes %}
  {% if rc.change_type == 'ESCALATED' or (rc.change_type == 'NEW' and rc.current_severity == 'HIGH') %}
    {% set _ = priority_changes.append(rc) %}
  {% else %}
    {% set _ = routine_changes.append(rc) %}
  {% endif %}
{% endfor %}

{% if priority_changes %}
<h4 style="margin:0.5rem 0 0.25rem; font-size:0.75rem; font-weight:700; color:#991b1b; text-transform:uppercase; letter-spacing:0.04em;">Material Changes (Require Attention)</h4>
<table class="data-table w-full text-sm my-2">
  <thead>
    <tr>
      <th class="text-left">Risk Factor</th>
      <th class="text-left">Category</th>
      <th class="text-center">Class</th>
      <th class="text-center">Change</th>
      <th class="text-center">Severity</th>
    </tr>
  </thead>
  <tbody>
    {% for rc in priority_changes %}
    <tr>
      <td>
        <span class="font-medium">{{ rc.title }}</span>
        {% if rc.change_type == 'REORGANIZED' and rc.prior_title %}
        <br><span class="text-xs text-gray-500">Previously: {{ rc.prior_title }}</span>
        {% else %}
        <br><span class="text-xs text-gray-500">{{ rc.summary }}</span>
        {% endif %}
      </td>
      <td><span class="text-xs">{{ rc.category }}</span></td>
      <td class="text-center">
        {% if rc.classification is defined and rc.classification %}
        <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold
          {% if rc.classification == 'ELEVATED' %}bg-red-100 text-red-800
          {% elif rc.classification == 'NOVEL' %}bg-blue-100 text-blue-800
          {% else %}bg-gray-100 text-gray-600{% endif %}">
          {{ rc.classification }}
        </span>
        {% else %}
        <span class="text-xs text-gray-400">&mdash;</span>
        {% endif %}
      </td>
      <td class="text-center">
        <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold
          {% if rc.badge_color == 'red' %}bg-red-100 text-red-800
          {% elif rc.badge_color == 'amber' %}bg-amber-100 text-amber-800
          {% elif rc.badge_color == 'blue' %}bg-blue-100 text-blue-800
          {% else %}bg-gray-100 text-gray-600{% endif %}">
          {{ rc.change_type }}
        </span>
      </td>
      <td class="text-center">
        <span class="text-xs {{ 'text-red-600 font-semibold' if rc.current_severity == 'HIGH' else 'text-amber-600' if rc.current_severity == 'MEDIUM' else 'text-gray-500' }}">
          {{ rc.current_severity }}
        </span>
        {% if rc.prior_severity and rc.prior_severity != 'N/A' and rc.prior_severity != rc.current_severity %}
        <span class="text-xs text-gray-400">&larr; {{ rc.prior_severity }}</span>
        {% endif %}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}

{% if routine_changes %}
{% set routine_new = routine_changes | selectattr('change_type', 'equalto', 'NEW') | list | length %}
{% set routine_removed = routine_changes | selectattr('change_type', 'equalto', 'REMOVED') | list | length %}
{% set routine_reorg = routine_changes | selectattr('change_type', 'equalto', 'REORGANIZED') | list | length %}
<div>
  <div style="font-weight:600;margin-bottom:4px">All Other Changes ({{ routine_changes | length }} items — {{ routine_new }} new, {{ routine_removed }} removed{% if routine_reorg %}, {{ routine_reorg }} reorganized{% endif %})</div>
  <div class="collapsible-content">
    <table class="data-table w-full text-sm">
      <thead>
        <tr>
          <th class="text-left">Risk Factor</th>
          <th class="text-left">Category</th>
          <th class="text-center">Class</th>
          <th class="text-center">Change</th>
          <th class="text-center">Severity</th>
        </tr>
      </thead>
      <tbody>
        {% for rc in routine_changes %}
        <tr>
          <td>
            <span class="font-medium">{{ rc.title }}</span>
            {% if rc.change_type == 'REORGANIZED' and rc.prior_title %}
            <br><span class="text-xs text-gray-500">Previously: {{ rc.prior_title }}</span>
            {% endif %}
          </td>
          <td><span class="text-xs">{{ rc.category }}</span></td>
          <td class="text-center">
            {% if rc.classification is defined and rc.classification %}
            <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold
              {% if rc.classification == 'ELEVATED' %}bg-red-100 text-red-800
              {% elif rc.classification == 'NOVEL' %}bg-blue-100 text-blue-800
              {% else %}bg-gray-100 text-gray-600{% endif %}">
              {{ rc.classification }}
            </span>
            {% else %}
            <span class="text-xs text-gray-400">&mdash;</span>
            {% endif %}
          </td>
          <td class="text-center">
            <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold
              {% if rc.badge_color == 'amber' %}bg-amber-100 text-amber-800
              {% elif rc.badge_color == 'red' %}bg-red-100 text-red-800
              {% elif rc.badge_color == 'green' %}bg-green-100 text-green-800
              {% elif rc.badge_color == 'blue' %}bg-blue-100 text-blue-800
              {% else %}bg-gray-100 text-gray-600{% endif %}">
              {{ rc.change_type }}
            </span>
          </td>
          <td class="text-center">
            <span class="text-xs {{ 'text-red-600 font-semibold' if rc.current_severity == 'HIGH' else 'text-amber-600' }}">
              {{ rc.current_severity }}
            </span>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endif %}
{% endif %}

{# --- Disclosure changes --- #}
{% if ten_k_yoy.disclosure_changes %}
<h4 class="mt-3 mb-1">Disclosure Changes</h4>
<div class="space-y-1">
  {% for dc in ten_k_yoy.disclosure_changes %}
  <div class="border-l-3 {{ 'border-red-500' if dc.do_relevance == 'HIGH' else 'border-amber-400' if dc.do_relevance == 'MEDIUM' else 'border-gray-300' }} pl-3 py-1">
    <p class="text-sm m-0">
      <span class="text-xs font-semibold uppercase text-gray-500">{{ dc.section }}</span>
      <span class="bg-{{ 'amber' if dc.change_type == 'NEW' else 'red' if dc.change_type == 'REMOVED' else 'blue' }}-100 text-{{ 'amber' if dc.change_type == 'NEW' else 'red' if dc.change_type == 'REMOVED' else 'blue' }}-700 text-xs px-1 rounded ml-1">{{ dc.change_type }}</span>
    </p>
    <p class="text-sm text-gray-700 m-0 mt-0.5">{{ dc.description }}</p>
  </div>
  {% endfor %}
</div>
{% endif %}

{% endif %}
