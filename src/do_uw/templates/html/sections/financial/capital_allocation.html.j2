{# Capital Allocation View — FCF deployment breakdown table #}
{% set cap = fin.get('capital_allocation', {}) %}
{% if cap and cap.get('components') %}
{% set border_color = '#DC2626' if cap.color == 'red' else ('#D97706' if cap.color == 'amber' else '#16A34A') %}
{% set bg_color = '#FEF2F2' if cap.color == 'red' else ('#FFFBEB' if cap.color == 'amber' else '#F0FDF4') %}
<h3>Capital Allocation</h3>
<div style="margin-bottom:0.75rem;">
  <div style="display:flex; align-items:baseline; gap:8px; margin-bottom:8px;">
    <span style="font-size:10px; font-weight:600; color:#6B7280; text-transform:uppercase; letter-spacing:0.3px;">Free Cash Flow:</span>
    <span style="font-size:13pt; font-weight:800; color:#1e3a5f; font-variant-numeric:tabular-nums;">{{ cap.fcf }}</span>
  </div>
  <table class="w-full border-collapse text-sm">
    <thead>
      <tr class="bg-navy text-white">
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-left p-1">Use of FCF</th>
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right p-1">Amount</th>
        <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right p-1">% of FCF</th>
      </tr>
    </thead>
    <tbody class="tabular-nums">
      {% for comp in cap.components %}
      <tr class="{{ 'bg-bg-alt' if loop.index is odd else 'bg-white' }}">
        <td class="p-1 font-heading text-xs font-semibold text-navy">{{ comp.label }}</td>
        <td class="p-1 text-right">{{ comp.amount }}</td>
        <td class="p-1 text-right">{{ comp.pct_of_fcf }}</td>
      </tr>
      {% endfor %}
      <tr style="border-top:2px solid #1e3a5f;">
        <td class="p-1 font-heading text-xs font-bold text-navy">Total Deployed</td>
        <td class="p-1"></td>
        <td class="p-1 text-right font-bold" style="color:{{ border_color }}">{{ cap.total_deployed_pct }}</td>
      </tr>
    </tbody>
  </table>
  {% if cap.color == 'red' %}
  <div style="margin-top:6px; padding:4px 8px; border-radius:4px; background:{{ bg_color }}; border:1px solid {{ border_color }}; font-size:10px; color:#991B1B; font-weight:600;">
    Distributions exceed 120% of FCF &mdash; shareholder returns funded by debt
  </div>
  {% elif cap.color == 'amber' %}
  <div style="margin-top:6px; padding:4px 8px; border-radius:4px; background:{{ bg_color }}; border:1px solid {{ border_color }}; font-size:10px; color:#92400E; font-weight:600;">
    Aggressive buyback allocation consuming &gt;80% of FCF
  </div>
  {% endif %}
</div>
{% endif %}
