{# Bankruptcy Risk Composite — unified distress score, only visible when score > 0 #}
{% set bk = fin.get('bankruptcy_composite', {}) %}
{% if bk and bk.score > 0 %}
{% set border_color = '#DC2626' if bk.color == 'red' else ('#D97706' if bk.color == 'amber' else '#16A34A') %}
{% set bg_color = '#FEF2F2' if bk.color == 'red' else ('#FFFBEB' if bk.color == 'amber' else '#F0FDF4') %}
{% set text_color = '#991B1B' if bk.color == 'red' else ('#92400E' if bk.color == 'amber' else '#166534') %}
<h3>Bankruptcy Risk Assessment</h3>
<div style="display:grid; grid-template-columns: auto 1fr; gap:0.75rem; margin-bottom:0.75rem; align-items:start;">
  <div style="padding:10px 16px; border-radius:5px; background:{{ bg_color }}; border:2px solid {{ border_color }}; text-align:center; min-width:80px;">
    <div style="font-size:18pt; font-weight:900; color:{{ text_color }}; font-variant-numeric:tabular-nums; line-height:1;">{{ bk.score }}</div>
    <div style="font-size:7pt; color:#6B7280; font-weight:600; margin-top:3px; text-transform:uppercase; letter-spacing:0.3px;">/ 100</div>
  </div>
  <div>
    <table class="w-full border-collapse text-sm">
      <thead>
        <tr class="bg-gray-100">
          <th class="font-heading text-xs font-semibold uppercase tracking-wider text-left p-1">Component</th>
          <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right p-1">Value</th>
          <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right p-1">Points</th>
          <th class="font-heading text-xs font-semibold uppercase tracking-wider text-left p-1">Status</th>
        </tr>
      </thead>
      <tbody class="tabular-nums">
        {% for comp in bk.components %}
        <tr class="{{ 'bg-red-50' if comp.points > 0 else '' }}">
          <td class="p-1 text-xs font-semibold text-navy">{{ comp.label }}</td>
          <td class="p-1 text-right text-xs">{{ comp.value }}</td>
          <td class="p-1 text-right text-xs font-bold{{ ' text-red-700' if comp.points > 0 else ' text-green-700' }}">{{ comp.points }}</td>
          <td class="p-1 text-xs">{{ comp.status }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% if bk.color == 'red' %}
<div style="padding:4px 8px; border-radius:4px; background:#FEF2F2; border:1px solid #DC2626; font-size:10px; color:#991B1B; font-weight:600; margin-bottom:8px;">
  Multiple converging distress indicators &mdash; elevated probability of financial failure and associated D&amp;O litigation
</div>
{% elif bk.color == 'amber' %}
<div style="padding:4px 8px; border-radius:4px; background:#FFFBEB; border:1px solid #D97706; font-size:10px; color:#92400E; font-weight:600; margin-bottom:8px;">
  Partial distress indicator convergence &mdash; monitor for further deterioration
</div>
{% endif %}
{% endif %}
