{# Refinancing Risk — short-term debt concentration + cash buffer #}
{% set refi = fin.get('refinancing_risk', {}) %}
{% if refi %}
{% set border_color = '#DC2626' if refi.color == 'red' else ('#D97706' if refi.color == 'amber' else '#16A34A') %}
{% set bg_color = '#FEF2F2' if refi.color == 'red' else ('#FFFBEB' if refi.color == 'amber' else '#F0FDF4') %}
{% set text_color = '#991B1B' if refi.color == 'red' else ('#92400E' if refi.color == 'amber' else '#166534') %}
<h3>Refinancing Risk</h3>
<div style="display:grid; grid-template-columns:repeat(3, 1fr); gap:0.4rem; margin-bottom:0.75rem;">
  <div style="padding:6px 8px; border-radius:5px; background:{{ bg_color }}; border:1.5px solid {{ border_color }}; text-align:center;">
    <div style="font-size:12pt; font-weight:800; color:{{ text_color }}; font-variant-numeric:tabular-nums; line-height:1;">{{ refi.st_debt_pct }}</div>
    <div style="font-size:6pt; color:#6B7280; font-weight:600; margin-top:2px; text-transform:uppercase; letter-spacing:0.3px;">Short-Term / Total Debt</div>
  </div>
  <div style="padding:6px 8px; border-radius:5px; background:#F8FAFC; border:1.5px solid #CBD5E1; text-align:center;">
    <div style="font-size:12pt; font-weight:800; color:#1e3a5f; font-variant-numeric:tabular-nums; line-height:1;">{{ refi.st_debt }}</div>
    <div style="font-size:6pt; color:#6B7280; font-weight:600; margin-top:2px; text-transform:uppercase; letter-spacing:0.3px;">Short-Term Debt</div>
  </div>
  <div style="padding:6px 8px; border-radius:5px; background:#F8FAFC; border:1.5px solid #CBD5E1; text-align:center;">
    <div style="font-size:12pt; font-weight:800; color:#1e3a5f; font-variant-numeric:tabular-nums; line-height:1;">{{ refi.days_cash }}</div>
    <div style="font-size:6pt; color:#6B7280; font-weight:600; margin-top:2px; text-transform:uppercase; letter-spacing:0.3px;">Days Cash on Hand</div>
  </div>
</div>
{% if refi.color == 'red' %}
<div style="padding:4px 8px; border-radius:4px; background:#FEF2F2; border:1px solid #DC2626; font-size:10px; color:#991B1B; font-weight:600; margin-bottom:8px;">
  Acute refinancing risk: high short-term debt concentration with insufficient liquidity buffer
</div>
{% elif refi.color == 'amber' %}
<div style="padding:4px 8px; border-radius:4px; background:#FFFBEB; border:1px solid #D97706; font-size:10px; color:#92400E; font-weight:600; margin-bottom:8px;">
  Elevated near-term maturity concentration &mdash; monitor upcoming maturities
</div>
{% endif %}
{% endif %}
