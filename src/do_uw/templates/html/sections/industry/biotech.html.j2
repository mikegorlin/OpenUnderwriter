{# ═══════════════════════════════════════════════════════════════════════════
   BIOTECH & LIFE SCIENCES — Industry-Specific D&O Analysis
   Four-pillar framework: Regulatory, Pipeline, Financial Resilience, Red Flags
   Only rendered when playbook is BIOTECH_PHARMA
   ═══════════════════════════════════════════════════════════════════════════ #}
{% set bio = biotech_industry %}
{% if bio and bio.is_biotech %}

{# Overall Risk Banner #}
{% set risk = bio.overall_risk %}
<div style="background:{{ risk.color }};color:white;padding:8px 12px;border-radius:5px;margin:8px 0;display:flex;justify-content:space-between;align-items:center">
  <div>
    <span style="font-size:11pt;font-weight:800">Biotech D&O Risk: {{ risk.level }}</span>
    <span style="font-size:8pt;opacity:0.8;margin-left:8px">Four-Pillar Framework Assessment</span>
  </div>
  <span style="font-size:8pt;font-weight:700;padding:2px 10px;background:rgba(255,255,255,0.2);border-radius:8px">{{ risk.factors | length }} risk factor{{ 's' if risk.factors | length != 1 }}</span>
</div>
{% if risk.factors %}
<div style="margin:4px 0 8px;padding:6px 10px;background:#FEF2F2;border-left:3px solid {{ risk.color }};border-radius:0 4px 4px 0">
  {% for f in risk.factors %}
  <div style="font-size:8.5pt;color:#7F1D1D;line-height:1.5">• {{ f }}</div>
  {% endfor %}
</div>
{% endif %}

{# ── PILLAR 1: Regulatory Pathway ── #}
{% set reg = bio.regulatory_pathway %}
<div style="border:1px solid #BFDBFE;border-radius:6px;padding:10px;margin-bottom:10px;background:#F8FBFF">
  <div style="font-size:8pt;font-weight:700;color:#1E40AF;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;border-bottom:2px solid #2563EB;padding-bottom:4px">Pillar 1 — Regulatory Pathway Classification</div>
  <div style="font-size:9pt;color:#374151">
    <span style="font-weight:700">Pathway:</span> {{ reg.pathway_type }}
    {% if reg.pathway_type == 'Drug/Biologic' %}
    <span style="font-size:8pt;color:#6B7280;margin-left:8px">(NDA/BLA review — standard 10mo, priority 6mo)</span>
    {% endif %}
  </div>
</div>

{# ── PILLAR 2: Clinical Pipeline ── #}
{% set pipe = bio.pipeline %}
<div style="border:1px solid #FECACA;border-radius:6px;padding:10px;margin-bottom:10px;background:#FFFBFB">
  <div style="font-size:8pt;font-weight:700;color:#991B1B;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;border-bottom:2px solid #DC2626;padding-bottom:4px">Pillar 2 — Clinical Pipeline & Phase Severity Scoring</div>

  {# Structure badge #}
  <div style="display:flex;gap:6px;margin-bottom:8px;flex-wrap:wrap">
    <div style="padding:4px 10px;border-radius:5px;background:white;border:1px solid #E5E7EB">
      <span style="font-size:7pt;color:#6B7280;font-weight:600;text-transform:uppercase">Structure</span><br>
      <span style="font-size:10pt;font-weight:800;color:{{ pipe.structure_color }}">{{ pipe.structure }}</span>
    </div>
    <div style="padding:4px 10px;border-radius:5px;background:white;border:1px solid #E5E7EB">
      <span style="font-size:7pt;color:#6B7280;font-weight:600;text-transform:uppercase">Pipeline Assets</span><br>
      <span style="font-size:10pt;font-weight:800;color:#374151">{{ pipe.asset_count }}</span>
    </div>
    <div style="padding:4px 10px;border-radius:5px;background:white;border:1px solid #E5E7EB">
      <span style="font-size:7pt;color:#6B7280;font-weight:600;text-transform:uppercase">Lead Asset Failure Survival</span><br>
      <span style="font-size:10pt;font-weight:800;color:{{ pipe.structure_color }}">{{ pipe.lead_asset_failure_survival }}</span>
    </div>
  </div>

  {# Pipeline table #}
  {% if pipe.assets %}
  <table style="width:100%;border-collapse:collapse;font-size:8pt;margin-bottom:6px">
    <thead>
      <tr style="background:#FEF2F2;border-bottom:1px solid #FECACA">
        <th style="text-align:left;padding:4px 6px;font-weight:700;color:#991B1B;font-size:7pt;text-transform:uppercase">Asset</th>
        <th style="text-align:center;padding:4px 6px;font-weight:700;color:#991B1B;font-size:7pt;text-transform:uppercase">Phase</th>
        <th style="text-align:left;padding:4px 6px;font-weight:700;color:#991B1B;font-size:7pt;text-transform:uppercase">Indication</th>
        <th style="text-align:center;padding:4px 6px;font-weight:700;color:#991B1B;font-size:7pt;text-transform:uppercase">D&O Risk</th>
        <th style="text-align:right;padding:4px 6px;font-weight:700;color:#991B1B;font-size:7pt;text-transform:uppercase">Advance Rate</th>
      </tr>
    </thead>
    <tbody>
      {% for asset in pipe.assets %}
      <tr style="border-bottom:1px solid #F3F4F6">
        <td style="padding:4px 6px;font-weight:700;color:#111827">{{ asset.name }}</td>
        <td style="padding:4px 6px;text-align:center">
          <span style="font-size:7pt;font-weight:700;padding:1px 6px;border-radius:8px;background:{{ asset.risk_color }};color:white">{{ asset.phase }}</span>
        </td>
        <td style="padding:4px 6px;color:#374151">{{ asset.indication }}</td>
        <td style="padding:4px 6px;text-align:center;font-weight:700;color:{{ asset.risk_color }}">{{ asset.risk_level }}</td>
        <td style="padding:4px 6px;text-align:right;font-variant-numeric:tabular-nums;color:#6B7280">{{ asset.advance_rate }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <div style="font-size:8.5pt;color:#6B7280;font-style:italic;padding:4px">Pipeline data extracted from 10-K risk factors — verify against company pipeline page for current status</div>
  {% endif %}

  <div style="font-size:7pt;color:#9CA3AF;margin-top:4px;line-height:1.4">
    Phase transition rates: Phase I→II: 52% | Phase II→III: 29% (highest attrition) | Phase III→NDA: 58% | NDA→Approval: 91%
    <br>Source: BIO Clinical Development Success Rates 2011-2020
  </div>
</div>

{# ── PILLAR 3: Financial Resilience ── #}
{% set fin = bio.financial_resilience %}
<div style="border:1px solid #1F3A5C;border-radius:6px;padding:10px;margin-bottom:10px;background:#FAFAFA">
  <div style="font-size:8pt;font-weight:700;color:#1F3A5C;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;border-bottom:2px solid #1F3A5C;padding-bottom:4px">Pillar 3 — Business Model & Financial Resilience</div>

  <div style="display:flex;gap:4px;flex-wrap:wrap;margin-bottom:8px">
    {# Revenue status #}
    <div style="flex:1;min-width:18%;background:white;border:1px solid #E5E7EB;border-radius:5px;padding:6px 8px;text-align:center">
      <div style="font-size:12pt;font-weight:800;color:{% if fin.has_revenue %}#16A34A{% else %}#DC2626{% endif %}">{{ fin.revenue if fin.has_revenue else 'Pre-Revenue' }}</div>
      <div style="font-size:6pt;color:#6B7280;font-weight:600;text-transform:uppercase;margin-top:1px">Revenue</div>
    </div>
    {# Cash #}
    <div style="flex:1;min-width:18%;background:white;border:1px solid #E5E7EB;border-radius:5px;padding:6px 8px;text-align:center">
      <div style="font-size:12pt;font-weight:800;color:#374151">{{ fin.cash }}</div>
      <div style="font-size:6pt;color:#6B7280;font-weight:600;text-transform:uppercase;margin-top:1px">Cash Position</div>
    </div>
    {# Burn rate #}
    <div style="flex:1;min-width:18%;background:white;border:1px solid #E5E7EB;border-radius:5px;padding:6px 8px;text-align:center">
      <div style="font-size:12pt;font-weight:800;color:#DC2626">{{ fin.burn_rate }}</div>
      <div style="font-size:6pt;color:#6B7280;font-weight:600;text-transform:uppercase;margin-top:1px">Burn Rate</div>
    </div>
    {# Runway #}
    <div style="flex:1;min-width:18%;background:white;border:1px solid #E5E7EB;border-radius:5px;padding:6px 8px;text-align:center">
      <div style="font-size:12pt;font-weight:800;color:{{ fin.runway_color }}">{{ fin.runway_months }}</div>
      <div style="font-size:6pt;color:#6B7280;font-weight:600;text-transform:uppercase;margin-top:1px">Cash Runway ({{ fin.runway_risk }})</div>
    </div>
    {# SCA tier #}
    <div style="flex:1;min-width:18%;background:white;border:1px solid #E5E7EB;border-radius:5px;padding:6px 8px;text-align:center">
      <div style="font-size:12pt;font-weight:800;color:{{ fin.mcap_sca_color }}">{{ fin.mcap_sca_tier }}</div>
      <div style="font-size:6pt;color:#6B7280;font-weight:600;text-transform:uppercase;margin-top:1px">SCA Frequency Tier</div>
    </div>
  </div>

  {% if fin.recent_offerings %}
  <div style="background:#FEF3C7;border-left:3px solid #D97706;padding:4px 8px;margin-top:4px;border-radius:0 4px 4px 0">
    <span style="font-size:7.5pt;font-weight:700;color:#92400E">Section 11/12 Exposure:</span>
    <span style="font-size:7.5pt;color:#78350F">{{ fin.dilution_risk }}</span>
  </div>
  {% endif %}
</div>

{# ── PILLAR 4: Red-Flag Audit ── #}
{% set audit = bio.red_flag_audit %}
<div style="border:1px solid #FDE68A;border-radius:6px;padding:10px;margin-bottom:10px;background:#FFFEF5">
  <div style="font-size:8pt;font-weight:700;color:#92400E;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;border-bottom:2px solid #D97706;padding-bottom:4px">Pillar 4 — Red-Flag Audit (Biotech Claim Drivers)</div>

  {% for flag in audit.flags %}
  <div style="display:flex;gap:8px;align-items:flex-start;padding:5px 0;{% if not loop.last %}border-bottom:1px solid #F3F4F6;{% endif %}">
    <span style="font-size:8pt;font-weight:700;padding:2px 8px;border-radius:8px;background:{{ flag.color }};color:white;flex-shrink:0;min-width:50px;text-align:center">{{ flag.status }}</span>
    <div>
      <div style="font-size:8.5pt;font-weight:700;color:#374151">{{ flag.name }}</div>
      <div style="font-size:8pt;color:#6B7280;line-height:1.4">{{ flag.detail }}</div>
    </div>
  </div>
  {% endfor %}

  <div style="font-size:7pt;color:#9CA3AF;margin-top:6px;line-height:1.3">
    Biotech SCA breakdown (2024): 57% pre-approval, 43% post-approval. 68% of development-stage claims dismissed at MTD.
    <br>Sources: Sidley Austin 2024, WTW 2025 Life Sciences Report, D&O Diary MTD Analysis 2005-2022.
  </div>
</div>

{% endif %}
