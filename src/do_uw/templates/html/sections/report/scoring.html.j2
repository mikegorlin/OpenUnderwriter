{# ═══════════════════════════════════════════════════════════════════════════
   MANIFEST SECTION 8: SCORING & UNDERWRITING — 10-factor model, probability
   ═══════════════════════════════════════════════════════════════════════════ #}
{% set sd = b.score_detail %}
{% if sd %}
<div id="scoring" style="margin-top:14px">
  <div style="background:#1F3A5C;color:white;padding:6px 10px;border-radius:4px;margin-bottom:6px;display:flex;justify-content:space-between;align-items:center">
    <div><span style="font-size:10pt;font-weight:800;letter-spacing:0.3px">Scoring & Underwriting</span><br><span style="font-size:7.5pt;color:rgba(255,255,255,0.6)">10-factor scoring model with signal-driven evaluation</span></div>
<div style="display:flex;gap:6px;align-items:center">
      <span style="font-size:9pt;color:rgba(255,255,255,0.7)">Quality Score</span>
      <span style="padding:3px 12px;border-radius:12px;font-size:11pt;font-weight:800;background:{{ sd.tier_color }};color:white">{{ sd.quality_score }}</span>
      <span style="padding:3px 10px;border-radius:12px;font-size:9pt;font-weight:700;background:rgba(255,255,255,0.15);color:white">{{ sd.tier_name }}</span>
    </div>
  </div>

  {% if sd._stage_banner is defined and sd._stage_banner %}
  <div style="background:#FEF3C7;border-left:4px solid #F59E0B;padding:8px 12px;margin-bottom:8px;font-size:9pt;color:#92400E;border-radius:0 4px 4px 0">
    {{ sd._stage_banner }}
  </div>
  {% endif %}

  {# ── LLM Critical Insight ── #}
  {% with insight_id="scoring" %}{% include "components/section_insight.html.j2" %}{% endwith %}

  {# Analytical narrative opener #}
  {% if sd.narrative %}
  <div style="font-size:10.5pt;color:#1F3A5C;line-height:1.6;margin:4px 0 8px;padding:10px 14px;background:#F0F4F8;border:1px solid #1F3A5C;border-radius:5px;border-left:4px solid #1F3A5C">
    {{ sd.narrative | strip_md }}
  </div>
  {% endif %}

  {# Factor score table with bar visualization #}
  <table style="width:100%;border-collapse:collapse;background:white;border:1px solid #E5E7EB;border-radius:5px;overflow:hidden">
    <tr style="background:#F9FAFB;border-bottom:1px solid #E5E7EB">
      <th style="text-align:left;padding:5px 8px;font-size:7pt;font-weight:600;color:#6B7280;text-transform:uppercase;width:14%">Factor</th>
      <th style="text-align:left;padding:5px 8px;font-size:7pt;font-weight:600;color:#6B7280;text-transform:uppercase;width:22%">Name</th>
      <th style="text-align:center;padding:5px 8px;font-size:7pt;font-weight:600;color:#6B7280;text-transform:uppercase;width:10%">Points</th>
      <th style="text-align:left;padding:5px 8px;font-size:7pt;font-weight:600;color:#6B7280;text-transform:uppercase;width:20%">Bar</th>
      <th style="text-align:center;padding:5px 8px;font-size:7pt;font-weight:600;color:#6B7280;text-transform:uppercase;width:10%">Signals</th>
      <th style="text-align:left;padding:5px 4px;font-size:7pt;font-weight:600;color:#6B7280;text-transform:uppercase;width:24%">Evidence</th>
    </tr>
    {% for f in sd.factor_rows %}
    <tr style="border-bottom:1px solid #F3F4F6">
      <td style="padding:4px 8px;font-size:11pt;font-weight:700;color:#1F3A5C">{{ f.factor_id | humanize_factor }}</td>
      <td style="padding:4px 8px;font-size:9.5pt;color:#374151">{{ f.name }}</td>
      <td style="padding:4px 8px;text-align:center;font-size:9pt;font-weight:700;color:{{ f.bar_color }}">{{ f.points }}<span style="color:#9CA3AF;font-weight:400">/{{ f.max_points }}</span></td>
      <td style="padding:4px 8px">
        <div style="background:#F3F4F6;border-radius:3px;height:10px;overflow:hidden;position:relative">
          <div style="background:{{ f.bar_color }};height:100%;width:{{ f.pct }}%;border-radius:3px;transition:width 0.3s"></div>
        </div>
      </td>
      <td style="padding:4px 8px;text-align:center;font-size:7.5pt;color:#6B7280">{{ f.triggered_signals }}/{{ f.total_signals }}</td>
      <td style="padding:4px 4px;font-size:7.5pt;color:#4B5563;line-height:1.3">{{ f.evidence }}</td>
    </tr>
    {% endfor %}
    <tr style="background:#F9FAFB;border-top:2px solid #E5E7EB">
      <td colspan="2" style="padding:5px 8px;font-size:11pt;font-weight:700;color:#1F3A5C">Total Risk Points</td>
      <td style="padding:5px 8px;text-align:center;font-size:9pt;font-weight:800;color:#DC2626">{{ sd.total_risk_points }}</td>
      <td colspan="3" style="padding:5px 8px;font-size:10.5pt;color:#374151">Quality Score: <b>{{ sd.quality_score }}</b> / 100 &rarr; <span style="font-weight:700;color:{{ sd.tier_color }}">{{ sd.tier_name }}</span></td>
    </tr>
  </table>

  {# Red flags #}
  {% if sd.red_flags %}
  <div style="margin-top:6px;background:#FEF2F2;border:1px solid #FECACA;border-radius:5px;padding:6px 10px">
    <div style="font-size:9pt;font-weight:700;color:#DC2626;margin-bottom:3px">Critical Risk Flags (Tier Ceiling Overrides)</div>
    {% for rf in sd.red_flags %}
    <div style="display:flex;gap:6px;padding:3px 0;align-items:center">
      <span style="display:inline-block;width:8px;height:8px;border-radius:4px;background:#DC2626;flex-shrink:0"></span>
      <span style="font-size:9pt;font-weight:600;color:#991B1B">{{ rf.name }}</span>
      {% if rf.max_tier %}<span style="font-size:7pt;padding:1px 6px;border-radius:8px;background:#DC2626;color:white">Max Tier: {{ rf.max_tier }}</span>{% endif %}
      {% for ev in rf.evidence %}<span style="font-size:7.5pt;color:#4B5563;margin-left:4px">{{ ev }}</span>{% endfor %}
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if sd.commentary_factual %}
  <div style="margin:6px 0">
    <div style="font-size:7pt;font-weight:700;color:#1F3A5C;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:3px">What Was Said</div>
    <div style="font-size:10.5pt;color:#374151;line-height:1.55;padding:6px 10px;background:#F9FAFB;border:1px solid #E5E7EB;border-radius:4px">{{ sd.commentary_factual | strip_md }}</div>
  </div>
  {% endif %}
  {% if sd.commentary_bullets %}
  <div style="margin:6px 0">
    <div style="font-size:7pt;font-weight:700;color:#1F3A5C;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:3px">Underwriting Commentary</div>
    <div style="font-size:10.5pt;color:#374151;line-height:1.55;padding:6px 10px;background:#EFF6FF;border:1px solid #BFDBFE;border-radius:4px;border-left:3px solid #2563EB">{{ sd.commentary_bullets | strip_md }}</div>
  </div>
  {% endif %}

  {# Full scoring detail — organized by analytical layer #}
  {% set sc = scoring or {} %}

  {# ── LAYER 1: Verdict & Scoring Model ── #}
  <div style="margin-top:12px;border:1px solid #E5E7EB;border-radius:6px;padding:10px;margin-bottom:12px;background:#FAFAFA">
    <div style="font-size:8pt;font-weight:700;color:#1F3A5C;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;border-bottom:2px solid #1F3A5C;padding-bottom:4px">Tier Classification & 10-Factor Model</div>
    {% include "sections/scoring/tier_classification.html.j2" %}
    {% include "sections/scoring/ten_factor_scoring.html.j2" %}
    {# factor_detail, waterfall_radar, probability_decomposition are already included by ten_factor_scoring #}
  </div>

  {# ── LAYER 2: Loss Analysis — What could the claim look like? ── #}
  <div style="border:1px solid #FECACA;border-radius:6px;padding:10px;margin-bottom:12px;background:#FFFBFB">
    <div style="font-size:8pt;font-weight:700;color:#991B1B;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;border-bottom:2px solid #DC2626;padding-bottom:4px">Loss Analysis — Probability, Severity & Tower Positioning</div>
    {% include "sections/scoring/claim_probability.html.j2" %}
    {% include "sections/scoring/severity_scenarios.html.j2" %}
    {% include "sections/scoring/scenario_analysis.html.j2" %}
    {% include "sections/investigative/settlement_tower.html.j2" ignore missing %}
    {% include "sections/scoring/tower_recommendation.html.j2" %}
  </div>

  {# ── LAYER 3: Peril Analysis — What type of claim? ── #}
  <div style="border:1px solid #FDE68A;border-radius:6px;padding:10px;margin-bottom:12px;background:#FFFEF5">
    <div style="font-size:8pt;font-weight:700;color:#92400E;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;border-bottom:2px solid #D97706;padding-bottom:4px">Peril Analysis — Claim Theories & Allegation Mapping</div>
    {% include "sections/scoring/peril_assessment.html.j2" %}
    {% include "sections/scoring/peril_map.html.j2" %}
    {% include "sections/scoring/allegation_mapping.html.j2" %}
  </div>

  {# ── LAYER 4: Investigative Depth — What signals are firing? ── #}
  <div style="border:1px solid #BFDBFE;border-radius:6px;padding:10px;margin-bottom:12px;background:#F8FBFF">
    <div style="font-size:8pt;font-weight:700;color:#1E40AF;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;border-bottom:2px solid #2563EB;padding-bottom:4px">Investigative Depth — Signals, Patterns & Forensics</div>
    {% include "sections/scoring/hazard_profile.html.j2" %}
    {% include "sections/scoring/forensic_composites.html.j2" %}
    {% include "sections/scoring/temporal_signals.html.j2" %}
    {% include "sections/scoring/pattern_detection.html.j2" %}
    {% include "sections/scoring/executive_risk_profile.html.j2" %}
  </div>

  {# ── LAYER 5: Underwriting Action — What to do about it? ── #}
  <div style="border:1px solid #BBF7D0;border-radius:6px;padding:10px;margin-bottom:12px;background:#F7FFF9">
    <div style="font-size:8pt;font-weight:700;color:#166534;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;border-bottom:2px solid #16A34A;padding-bottom:4px">Underwriting Action — Posture, Watch Items & Calibration</div>
    {% include "sections/scoring/underwriting_posture.html.j2" %}
    {% include "sections/scoring/watch_items.html.j2" %}
    {% include "sections/scoring/calibration_notes.html.j2" %}
    {% include "sections/scoring/zero_verification.html.j2" %}
    {% include "sections/scoring/scoring_checks.html.j2" %}
  </div>
</div>
{% endif %}
