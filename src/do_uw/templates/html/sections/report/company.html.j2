    </div>
    {% if co.disruption_risk.threats %}
    <div style="display:flex;flex-wrap:wrap;gap:4px">
      {% for threat in co.disruption_risk.threats %}
      <span style="font-size:9pt;padding:2px 6px;background:rgba(0,0,0,0.05);border-radius:8px;color:#374151">{{ threat }}</span>
      {% endfor %}
    </div>
    {% endif %}
  </div>
  {% endif %}

  {# Operations detail cards: 2 rows #}
