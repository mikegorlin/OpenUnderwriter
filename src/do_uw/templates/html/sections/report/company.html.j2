    <span style="font-size:11pt;font-weight:700;color:#1F3A5C">Event Timeline</span>
    {% if co.ma_amount != 'N/A' %}<span style="font-size:7.5pt;color:#6B7280">M&A Net Cash: {{ co.ma_amount }}</span>{% endif %}
  </div>
  {% if co.events %}
  <table style="width:100%;border-collapse:collapse;font-size:8pt;margin-bottom:6px">
    <tr style="background:#F9FAFB;border-bottom:1px solid #E5E7EB">
      <th style="text-align:left;padding:3px 4px;font-weight:600;color:#6B7280;font-size:6.5pt;text-transform:uppercase;width:80px">Date</th>
      <th style="text-align:left;padding:3px 4px;font-weight:600;color:#6B7280;font-size:6.5pt;text-transform:uppercase;width:70px">Type</th>
      <th style="text-align:left;padding:3px 4px;font-weight:600;color:#6B7280;font-size:6.5pt;text-transform:uppercase">Event</th>
      <th style="text-align:center;padding:3px 4px;font-weight:600;color:#6B7280;font-size:6.5pt;text-transform:uppercase;width:60px">D&O Flag</th>
    </tr>
    {% for ev in co.events %}
    {# Classify D&O risk by event type and content #}
    {% set ev_type = ev.type | lower %}
    {% set ev_text = ev.event | lower %}
    {% if ev_type == 'officer_change' or 'departing' in ev_text or 'resignation' in ev_text or 'terminated' in ev_text %}
      {% set flag_color = '#DC2626' %}
      {% set flag_label = 'FLAG' %}
      {% set flag_tip = 'Executive departure — Side A exposure, scienter inference' %}
      {% set row_bg = '#FEF2F2' %}
    {% elif ev_type == 'agreement' or 'convertible' in ev_text or 'debt' in ev_text or 'notes' in ev_text %}
      {% set flag_color = '#D97706' %}
      {% set flag_label = 'WATCH' %}
      {% set flag_tip = 'Capital structure change — Section 11 offering exposure' %}
      {% set row_bg = '#FFFBEB' %}
    {% elif ev_type == 'shareholder_vote' and ('say-on-pay' in ev_text or 'compensation' in ev_text) %}
      {% set flag_color = '#D97706' %}
      {% set flag_label = 'WATCH' %}
      {% set flag_tip = 'Compensation vote — derivative suit risk if failed' %}
      {% set row_bg = '#FFFBEB' %}
    {% elif ev_type == 'material_event' %}
      {% set flag_color = '#D97706' %}
      {% set flag_label = 'REVIEW' %}
      {% set flag_tip = '8-K material event — review for disclosure implications' %}
      {% set row_bg = '#FFFBEB' %}
    {% elif ev_type == 'earnings' and ('miss' in ev_text or 'decline' in ev_text or 'loss' in ev_text) %}
      {% set flag_color = '#DC2626' %}
      {% set flag_label = 'FLAG' %}
      {% set flag_tip = 'Earnings miss — potential 10b-5 trigger event' %}
      {% set row_bg = '#FEF2F2' %}
    {% else %}
      {% set flag_color = '#16A34A' %}
      {% set flag_label = '—' %}
      {% set flag_tip = '' %}
      {% set row_bg = 'white' %}
    {% endif %}
    <tr style="border-bottom:1px solid #F3F4F6;background:{{ row_bg }}">
      <td style="padding:3px 4px;color:#6B7280;white-space:nowrap">{{ ev.date }}</td>
      <td style="padding:3px 4px"><span style="font-size:7pt;font-weight:600;padding:1px 4px;border-radius:6px;background:{% if flag_label == 'FLAG' %}#FEE2E2;color:#991B1B{% elif flag_label in ('WATCH', 'REVIEW') %}#FEF3C7;color:#92400E{% else %}#EFF6FF;color:#1D4ED8{% endif %}">{{ ev.type }}</span></td>
      <td style="padding:3px 4px;color:#111827">{{ ev.event }}{% if flag_tip %}<br><span style="font-size:7pt;color:{{ flag_color }};font-style:italic">{{ flag_tip }}</span>{% endif %}</td>
      <td style="text-align:center;padding:3px 4px">{% if flag_label != '—' %}<span style="font-size:7pt;font-weight:700;padding:1px 6px;border-radius:8px;background:{{ flag_color }};color:white">{{ flag_label }}</span>{% else %}<span style="color:#D1D5DB">—</span>{% endif %}</td>
    </tr>
    {% endfor %}
  </table>
  {% endif %}
  {% endif %}

