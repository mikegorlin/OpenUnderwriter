    <div style="flex:1;min-width:23%;background:white;border:1px solid #E5E7EB;border-radius:5px;padding:6px 8px">
      <div style="font-size:8pt;color:#7C3AED;text-transform:uppercase;letter-spacing:0.5px;font-weight:700;margin-bottom:3px">Subsidiary Structure</div>
      <div style="display:flex;justify-content:space-between;padding:1.5px 0"><span style="font-size:7.5pt;color:#6B7280">Subsidiaries</span><span style="font-size:8pt;font-weight:700">{{ co.subsidiary_structure.count }}</span></div>
      <div style="display:flex;justify-content:space-between;padding:1.5px 0"><span style="font-size:7.5pt;color:#6B7280">Jurisdictions</span><span style="font-size:8pt;font-weight:700">{{ co.subsidiary_structure.jurisdictions }}</span></div>
      <div style="display:flex;justify-content:space-between;padding:1.5px 0"><span style="font-size:7.5pt;color:#6B7280">High-Reg</span><span style="font-size:8pt;font-weight:700">{{ co.subsidiary_structure.high_reg }}</span></div>
      <div style="display:flex;justify-content:space-between;padding:1.5px 0"><span style="font-size:7.5pt;color:#6B7280">Low-Reg</span><span style="font-size:8pt;font-weight:700">{{ co.subsidiary_structure.low_reg }}</span></div>
    </div>
    {% endif %}

    {# 2.8.2 Workforce distribution #}
    {% if co.workforce and co.workforce.total != 'N/A' %}
    <div style="flex:1;min-width:23%;background:white;border:1px solid #E5E7EB;border-radius:5px;padding:6px 8px">
      <div style="font-size:8pt;color:#0891B2;text-transform:uppercase;letter-spacing:0.5px;font-weight:700;margin-bottom:3px">Workforce</div>
      <div style="font-size:15pt;font-weight:800;color:#374151;line-height:1">{{ co.workforce.total }}</div>
      {% if co.workforce.domestic and co.workforce.domestic != 'N/A' %}<div style="display:flex;justify-content:space-between;padding:1.5px 0;margin-top:4px"><span style="font-size:7.5pt;color:#6B7280">Domestic</span><span style="font-size:8pt;font-weight:700">{{ co.workforce.domestic }}</span></div>{% endif %}
      {% if co.workforce.international and co.workforce.international != 'N/A' %}<div style="display:flex;justify-content:space-between;padding:1.5px 0"><span style="font-size:7.5pt;color:#6B7280">International</span><span style="font-size:8pt;font-weight:700">{{ co.workforce.international }}</span></div>{% endif %}
    </div>
    {% endif %}

    {# 2.8.3 Operational complexity (pill badges) #}
    {% if co.op_complexity %}
    <div style="flex:1;min-width:23%;background:white;border:1px solid #E5E7EB;border-radius:5px;padding:6px 8px">
      <div style="font-size:8pt;color:#D97706;text-transform:uppercase;letter-spacing:0.5px;font-weight:700;margin-bottom:3px">Complexity Flags</div>
      <div style="display:flex;flex-direction:column;gap:4px;margin-top:4px">
        <div style="display:flex;justify-content:space-between;align-items:center"><span style="font-size:9.5pt;color:#374151">VIE Structures</span><span style="font-size:7pt;font-weight:700;padding:1px 6px;border-radius:8px;background:{% if co.op_complexity.has_vie %}#FEF2F2;color:#DC2626{% else %}#F0FDF4;color:#16A34A{% endif %}">{% if co.op_complexity.has_vie %}Yes{% else %}No{% endif %}</span></div>
        <div style="display:flex;justify-content:space-between;align-items:center"><span style="font-size:9.5pt;color:#374151">SPE Structures</span><span style="font-size:7pt;font-weight:700;padding:1px 6px;border-radius:8px;background:{% if co.op_complexity.has_spe %}#FEF2F2;color:#DC2626{% else %}#F0FDF4;color:#16A34A{% endif %}">{% if co.op_complexity.has_spe %}Yes{% else %}No{% endif %}</span></div>
        <div style="display:flex;justify-content:space-between;align-items:center"><span style="font-size:9.5pt;color:#374151">Dual-Class Stock</span><span style="font-size:7pt;font-weight:700;padding:1px 6px;border-radius:8px;background:{% if co.op_complexity.has_dual_class %}#FEF2F2;color:#DC2626{% else %}#F0FDF4;color:#16A34A{% endif %}">{% if co.op_complexity.has_dual_class %}Yes{% else %}No{% endif %}</span></div>
      </div>
    </div>
    {% endif %}

    {# 2.8.5 Key person risk #}
    {% if co.key_person and co.key_person.risk_score != 'N/A' %}
    <div style="flex:1;min-width:23%;background:white;border:1px solid #E5E7EB;border-radius:5px;padding:6px 8px;border-left:3px solid {{ co.key_person.color }}">
      <div style="font-size:8pt;color:#DC2626;text-transform:uppercase;letter-spacing:0.5px;font-weight:700;margin-bottom:3px">Key Person Risk</div>
      <div style="font-size:15pt;font-weight:800;color:{{ co.key_person.color }};line-height:1">{{ co.key_person.risk_score }}<span style="font-size:8pt;color:#6B7280">/10</span></div>
      <div style="display:flex;justify-content:space-between;padding:1.5px 0;margin-top:4px"><span style="font-size:7.5pt;color:#6B7280">Founder-Led</span><span style="font-size:8pt;font-weight:700">{% if co.key_person.is_founder_led %}Yes{% else %}No{% endif %}</span></div>
      {% if co.key_person.ceo_tenure %}<div style="display:flex;justify-content:space-between;padding:1.5px 0"><span style="font-size:7.5pt;color:#6B7280">CEO Tenure</span><span style="font-size:8pt;font-weight:700">{{ co.key_person.ceo_tenure }}yr</span></div>{% endif %}
      <div style="display:flex;justify-content:space-between;padding:1.5px 0"><span style="font-size:7.5pt;color:#6B7280">Succession Plan</span><span style="font-size:8pt;font-weight:700">{% if co.key_person.has_succession_plan %}Yes{% elif co.key_person.has_succession_plan is sameas false %}No{% else %}<span style="color:#9CA3AF">Not disclosed</span>{% endif %}</span></div>
    </div>
    {% endif %}
  </div>

  {# 2.8.4 Operational resilience (compact KV table) #}
  {% if co.op_resilience and (co.op_resilience.geographic_concentration != 'N/A' or co.op_resilience.supply_chain_depth != 'N/A') %}
  <div style="background:white;border:1px solid #E5E7EB;border-radius:5px;padding:6px 10px;margin-bottom:6px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:3px">
      <span style="font-size:8pt;color:#1F3A5C;text-transform:uppercase;letter-spacing:0.5px;font-weight:700">Operational Resilience</span>
