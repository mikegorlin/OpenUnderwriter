    </div>
    <div style="display:flex;flex-wrap:wrap;gap:12px">
      {% if co.op_resilience.geographic_concentration != 'N/A' %}<div><span style="font-size:7.5pt;color:#6B7280">Geography: </span><span style="font-size:8pt;font-weight:600;color:#111827">{{ co.op_resilience.geographic_concentration }}</span></div>{% endif %}
      {% if co.op_resilience.supply_chain_depth != 'N/A' %}<div><span style="font-size:7.5pt;color:#6B7280">Supply Chain: </span><span style="font-size:8pt;font-weight:600;color:#111827">{{ co.op_resilience.supply_chain_depth }}</span></div>{% endif %}
      {% if co.op_resilience.facility_risk != 'N/A' %}<div><span style="font-size:7.5pt;color:#6B7280">Facilities: </span><span style="font-size:8pt;font-weight:600;color:#111827">{{ co.op_resilience.facility_risk }}</span></div>{% endif %}
    </div>
  </div>
