{# ═══════════════════════════════════════════════════════════════════════════
   MANIFEST 1.9: EXECUTIVE SUMMARY & RECOMMENDATION (part of Decision Dashboard)
   ═══════════════════════════════════════════════════════════════════════════ #}
{% set es = b.exec_summary %}
{% if es %}
<div id="executive-brief" style="margin-top:14px">
  <div style="background:#1F3A5C;color:white;padding:6px 10px;border-radius:4px;margin-bottom:6px;display:flex;justify-content:space-between;align-items:center">
    <div><span style="font-size:10pt;font-weight:800;letter-spacing:0.3px">Executive Summary & Recommendation</span><br><span style="font-size:7.5pt;color:rgba(255,255,255,0.6)">Underwriting thesis and risk assessment</span></div>
<div style="display:flex;gap:6px;align-items:center">
      <span style="padding:3px 12px;border-radius:12px;font-size:9pt;font-weight:700;background:{{ es.tier_color }};color:white">{{ es.tier_name }}</span>
      {% if es.claim_range %}<span style="font-size:7.5pt;opacity:0.7">Claim Prob: {{ es.claim_range }}</span>{% endif %}
    </div>
  </div>

  {# Recommendation box #}
  <div style="border-left:4px solid {{ es.tier_color }};background:white;border:1px solid #E5E7EB;border-left:4px solid {{ es.tier_color }};border-radius:0 5px 5px 0;padding:10px 14px;margin-bottom:8px">
    <div style="font-size:9pt;font-weight:700;color:{{ es.tier_color }};margin-bottom:4px">{{ es.tier_name }} — {{ es.tier_action }}</div>
    {% if es.probability_range %}<div style="font-size:8pt;color:#6B7280;margin-bottom:4px">Probability Band: {{ es.probability_range }} | Claim Band: {{ es.claim_band }}</div>{% endif %}
  </div>

  {# Red Flags #}
  {% if es.red_flags %}
  <div style="background:#FEF2F2;border:1px solid #FECACA;border-radius:5px;padding:6px 10px;margin-bottom:8px">
    <div style="font-size:9pt;font-weight:700;color:#DC2626;margin-bottom:4px">Critical Red Flags</div>
    {% for rf in es.red_flags %}
    <div style="display:flex;gap:6px;padding:3px 0;{% if not loop.last %}border-bottom:1px solid #FEE2E2;{% endif %}">
      <span style="display:inline-block;width:8px;height:8px;border-radius:4px;background:#DC2626;margin-top:4px;flex-shrink:0"></span>
      <div>
        <span style="font-size:9pt;font-weight:600;color:#991B1B">{{ rf.name }}</span>
        {% if rf.max_tier %}<span style="font-size:7pt;color:#DC2626;margin-left:4px">(Ceiling: {{ rf.max_tier }})</span>{% endif %}
        {% for ev in rf.evidence %}<div style="font-size:8pt;color:#4B5563;line-height:1.4">{{ ev }}</div>{% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {# Key Negatives & Positives side by side #}
  <table style="width:100%;border-collapse:separate;border-spacing:4px 0"><tr>
    {# Negatives #}
    <td style="width:50%;vertical-align:top">
      <div style="background:#F3F4F6;padding:4px 8px;border-radius:3px;margin-bottom:4px"><span style="font-size:9pt;font-weight:700;color:#DC2626">Key Negatives</span></div>
      {% for neg in es.key_negatives %}
      <div style="padding:4px 0;{% if not loop.last %}border-bottom:1px solid #F3F4F6;{% endif %}">
        <div style="display:flex;justify-content:space-between;align-items:center">
          <span style="font-size:9pt;font-weight:600;color:#111827">{{ neg.name }}</span>
          <span style="font-size:7.5pt;font-weight:700;color:white;background:#DC2626;padding:1px 6px;border-radius:8px">{{ neg.points }}/{{ neg.max }}</span>
        </div>
        {% if neg.evidence %}<div style="font-size:8pt;color:#4B5563;line-height:1.4;margin-top:2px;word-wrap:break-word">{{ neg.evidence | strip_jargon }}</div>{% endif %}
      </div>
      {% endfor %}
      {% if not es.key_negatives %}<div style="font-size:9pt;color:#16A34A;padding:4px 0">No significant negatives identified</div>{% endif %}
    </td>
    {# Positives #}
    <td style="width:50%;vertical-align:top">
      <div style="background:#F3F4F6;padding:4px 8px;border-radius:3px;margin-bottom:4px"><span style="font-size:9pt;font-weight:700;color:#16A34A">Key Positives</span></div>
      {% for pos in es.key_positives %}
      <div style="padding:4px 0;{% if not loop.last %}border-bottom:1px solid #F3F4F6;{% endif %}">
        <div style="display:flex;justify-content:space-between;align-items:center">
          <span style="font-size:9pt;font-weight:600;color:#111827">{{ pos.name }}</span>
          <span style="font-size:7.5pt;font-weight:700;color:white;background:#16A34A;padding:1px 6px;border-radius:8px">{{ pos.points }}/{{ pos.max }}</span>
        </div>
        {% if pos.evidence %}<div style="font-size:8pt;color:#4B5563;line-height:1.4;margin-top:2px;word-wrap:break-word">{{ pos.evidence | strip_jargon }}</div>{% endif %}
      </div>
      {% endfor %}
      {% if not es.key_positives %}<div style="font-size:9pt;color:#6B7280;padding:4px 0">No standout positives</div>{% endif %}
    </td>
  </tr></table>

  {# Structured narrative — thesis, risk points, mitigants, conditions #}
  {% set ns = es.narrative_structured if es.narrative_structured is defined else {} %}
  {% if ns and ns.thesis %}
  <div style="font-size:10.5pt;color:#374151;line-height:1.6;margin:8px 0;padding:10px 14px;background:#F8FAFC;border-left:3px solid #1F3A5C;border-radius:0 4px 4px 0">
    <div style="font-size:9.5pt;font-weight:700;color:#1F3A5C;margin-bottom:6px;line-height:1.5">{{ ns.thesis }}</div>
    {% if ns.risk_points %}
    <div style="margin-bottom:6px">
      <div style="font-size:7pt;font-weight:700;color:#DC2626;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:3px">Risk Factors</div>
      <ul style="margin:0;padding-left:14px;font-size:8.5pt;line-height:1.55">
        {% for rp in ns.risk_points %}<li style="margin-bottom:2px;color:#374151">{{ rp }}</li>{% endfor %}
      </ul>
    </div>
    {% endif %}
    {% if ns.mitigants %}
    <div style="margin-bottom:6px">
      <div style="font-size:7pt;font-weight:700;color:#16A34A;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:3px">Mitigating Factors</div>
      <ul style="margin:0;padding-left:14px;font-size:8.5pt;line-height:1.55">
        {% for mp in ns.mitigants %}<li style="margin-bottom:2px;color:#374151">{{ mp }}</li>{% endfor %}
      </ul>
    </div>
    {% endif %}
    {% if ns.conditions %}
    <div style="margin-bottom:4px">
      <div style="font-size:7pt;font-weight:700;color:#D97706;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:3px">Recommended Conditions</div>
      <ol style="margin:0;padding-left:16px;font-size:8.5pt;line-height:1.55">
        {% for cond in ns.conditions %}<li style="margin-bottom:2px;color:#374151">{{ cond }}</li>{% endfor %}
      </ol>
    </div>
    {% endif %}
    {% if ns.recommendation %}
    <div style="font-size:8.5pt;font-weight:600;color:#1F3A5C;margin-top:6px;padding-top:6px;border-top:1px solid #E5E7EB">{{ ns.recommendation }}</div>
    {% endif %}
  </div>
  {% elif es.narrative %}
  <div style="font-size:10.5pt;color:#374151;line-height:1.6;margin:8px 0;padding:8px 12px;background:#F8FAFC;border-left:3px solid #1F3A5C;border-radius:0 4px 4px 0">
    {{ es.narrative | strip_md }}
  </div>
  {% endif %}
  {# Dual-voice commentary #}
  {% if es.commentary_factual %}
  <div style="margin:6px 0">
    <div style="font-size:7pt;font-weight:700;color:#1F3A5C;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:3px">What Was Said</div>
    <div style="font-size:10.5pt;color:#374151;line-height:1.55;padding:6px 10px;background:#F9FAFB;border:1px solid #E5E7EB;border-radius:4px">{{ es.commentary_factual | strip_md }}</div>
  </div>
  {% endif %}
  {% if es.commentary_bullets %}
  <div style="margin:6px 0">
    <div style="font-size:7pt;font-weight:700;color:#1F3A5C;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:3px">Underwriting Commentary</div>
    <div style="font-size:10.5pt;color:#374151;line-height:1.55;padding:6px 10px;background:#EFF6FF;border:1px solid #BFDBFE;border-radius:4px;border-left:3px solid #2563EB">{{ es.commentary_bullets | strip_md }}</div>
  </div>
  {% endif %}
</div>
{% endif %}
