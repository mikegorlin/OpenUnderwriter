{# Litigation Timeline Events — SECT6-10
   Visual vertical timeline with colored dots by event type:
   SCA/case_filing = red, regulatory/enforcement = amber, settlement = blue,
   stock_drop/executive_change = amber, other = gray #}

  {# --- Litigation Timeline --- #}
  {% set events = lit.get('timeline_events', []) %}
  {% if events %}
  <h3>Litigation Timeline</h3>
  <div style="position:relative; padding-left:24px; margin:0.5rem 0 1rem;">
    {# Vertical line #}
    <div style="position:absolute; left:7px; top:0; bottom:0; width:2px; background:#D1D5DB;"></div>
    {% for evt in events %}
    {# Dot color by type #}
    {% set etype = evt.type | default('other') | lower %}
    {% if etype in ('case_filing', 'sca', 'securities_class_action') %}
      {% set dot_color = '#DC2626' %}
      {% set dot_border = '#FCA5A5' %}
    {% elif etype in ('enforcement_action', 'regulatory') %}
      {% set dot_color = '#D97706' %}
      {% set dot_border = '#FCD34D' %}
    {% elif etype in ('derivative', 'derivative_suit') %}
      {% set dot_color = '#2563EB' %}
      {% set dot_border = '#93C5FD' %}
    {% elif etype == 'settlement' %}
      {% set dot_color = '#16A34A' %}
      {% set dot_border = '#86EFAC' %}
    {% elif etype in ('stock_drop', 'executive_change') %}
      {% set dot_color = '#D97706' %}
      {% set dot_border = '#FCD34D' %}
    {% else %}
      {% set dot_color = '#6B7280' %}
      {% set dot_border = '#D1D5DB' %}
    {% endif %}
    <div style="position:relative; margin-bottom:0.6rem; padding-left:12px;">
      {# Dot #}
      <div style="position:absolute; left:-20px; top:2px; width:10px; height:10px; border-radius:50%; background:{{ dot_color }}; border:2px solid {{ dot_border }};"></div>
      {# Date label #}
      {% if evt.date and evt.date != 'N/A' %}<span style="font-size:7pt; font-weight:700; color:#6B7280; font-variant-numeric:tabular-nums; margin-right:6px;">{{ evt.date }}</span>{% endif %}
      {# Type badge #}
      {% set type_display = etype | replace('_', ' ') | title %}
      {% if etype in ('case_filing', 'sca', 'securities_class_action', 'enforcement_action') %}
      <span style="display:inline-block; font-size:6pt; font-weight:600; padding:1px 4px; border-radius:3px; background:#FEF2F2; border:1px solid #FECACA; color:#991B1B; vertical-align:middle;">{{ type_display }}</span>
      {% elif etype == 'settlement' %}
      <span style="display:inline-block; font-size:6pt; font-weight:600; padding:1px 4px; border-radius:3px; background:#F0FDF4; border:1px solid #BBF7D0; color:#166534; vertical-align:middle;">{{ type_display }}</span>
      {% elif etype in ('derivative', 'derivative_suit') %}
      <span style="display:inline-block; font-size:6pt; font-weight:600; padding:1px 4px; border-radius:3px; background:#EFF6FF; border:1px solid #BFDBFE; color:#1E40AF; vertical-align:middle;">{{ type_display }}</span>
      {% else %}
      <span style="display:inline-block; font-size:6pt; font-weight:600; padding:1px 4px; border-radius:3px; background:#FFFBEB; border:1px solid #FDE68A; color:#92400E; vertical-align:middle;">{{ type_display }}</span>
      {% endif %}
      {# Description #}
      <div style="font-size:8pt; color:#374151; margin-top:1px; line-height:1.4;">{{ evt.description | default('') }}</div>
      {# Severity indicator #}
      {% set sev = evt.severity | default('') | upper %}
      {% if sev == 'HIGH' %}
      <span style="font-size:6pt; font-weight:600; color:#DC2626;">HIGH SEVERITY</span>
      {% elif sev == 'MEDIUM' %}
      <span style="font-size:6pt; font-weight:600; color:#D97706;">MEDIUM</span>
      {% endif %}
    </div>
    {% endfor %}
  </div>
  {% endif %}
