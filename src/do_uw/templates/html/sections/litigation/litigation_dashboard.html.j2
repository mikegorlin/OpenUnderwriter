{# Litigation Dashboard — at-a-glance summary of all litigation activity.
   Shows matter counts, reserve, SOL windows, and SEC status in a compact grid. #}

{% set dash = lit.get('dashboard', {}) %}
{% if dash %}
<h3>Litigation Overview</h3>
<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin: 12px 0;">
  {# Active Matters #}
  <div style="background: {{ '#fef2f2' if dash.active_count > 0 else '#f0fdf4' }}; border-radius: 6px; padding: 12px; text-align: center; border: 1px solid {{ '#fecaca' if dash.active_count > 0 else '#bbf7d0' }};">
    <div style="font-size: 24px; font-weight: 700; color: {{ '#dc2626' if dash.active_count > 0 else '#16a34a' }}; font-variant-numeric: tabular-nums;">{{ dash.active_count }}</div>
    <div style="font-size: 10px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">Active Matters</div>
  </div>
  {# Regulatory #}
  <div style="background: {{ '#fffbeb' if dash.regulatory_count > 0 else '#f8fafc' }}; border-radius: 6px; padding: 12px; text-align: center; border: 1px solid {{ '#fde68a' if dash.regulatory_count > 0 else '#e2e8f0' }};">
    <div style="font-size: 24px; font-weight: 700; color: {{ '#d97706' if dash.regulatory_count > 0 else '#64748b' }}; font-variant-numeric: tabular-nums;">{{ dash.regulatory_count }}</div>
    <div style="font-size: 10px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">Regulatory Actions</div>
  </div>
  {# Contingent Liabilities #}
  <div style="background: {{ '#fffbeb' if dash.contingent_count > 0 else '#f8fafc' }}; border-radius: 6px; padding: 12px; text-align: center; border: 1px solid {{ '#fde68a' if dash.contingent_count > 0 else '#e2e8f0' }};">
    <div style="font-size: 24px; font-weight: 700; color: {{ '#d97706' if dash.contingent_count > 0 else '#64748b' }}; font-variant-numeric: tabular-nums;">{{ dash.contingent_count }}</div>
    <div style="font-size: 10px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">Contingent Liab.</div>
  </div>
  {# Litigation Reserve #}
  <div style="background: #f8fafc; border-radius: 6px; padding: 12px; text-align: center; border: 1px solid #e2e8f0;">
    <div style="font-size: 24px; font-weight: 700; color: #1e3a5f; font-variant-numeric: tabular-nums;">{{ dash.litigation_reserve }}</div>
    <div style="font-size: 10px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">Litigation Reserve</div>
  </div>
</div>

{# Second row: SOL Windows, SEC Pipeline, Defense, Derivatives #}
<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin: 0 0 16px 0;">
  <div style="background: {{ '#fef2f2' if dash.open_sol_windows > 0 else '#f8fafc' }}; border-radius: 6px; padding: 12px; text-align: center; border: 1px solid {{ '#fecaca' if dash.open_sol_windows > 0 else '#e2e8f0' }};">
    <div style="font-size: 24px; font-weight: 700; color: {{ '#dc2626' if dash.open_sol_windows > 0 else '#64748b' }}; font-variant-numeric: tabular-nums;">{{ dash.open_sol_windows }}/{{ dash.total_sol_windows }}</div>
    <div style="font-size: 10px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">Open SOL Windows</div>
  </div>
  <div style="background: #f8fafc; border-radius: 6px; padding: 12px; text-align: center; border: 1px solid #e2e8f0;">
    <div style="font-size: 18px; font-weight: 700; color: {{ '#16a34a' if dash.sec_stage == 'NONE' else '#dc2626' }};">{{ dash.sec_stage }}</div>
    <div style="font-size: 10px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">SEC Pipeline</div>
  </div>
  <div style="background: #f8fafc; border-radius: 6px; padding: 12px; text-align: center; border: 1px solid #e2e8f0;">
    <div style="font-size: 18px; font-weight: 700; color: #1e3a5f;">{{ dash.defense_strength | humanize }}</div>
    <div style="font-size: 10px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">Defense Strength</div>
  </div>
  <div style="background: {{ '#fffbeb' if dash.derivative_count > 0 else '#f8fafc' }}; border-radius: 6px; padding: 12px; text-align: center; border: 1px solid {{ '#fde68a' if dash.derivative_count > 0 else '#e2e8f0' }};">
    <div style="font-size: 24px; font-weight: 700; color: {{ '#d97706' if dash.derivative_count > 0 else '#64748b' }}; font-variant-numeric: tabular-nums;">{{ dash.derivative_count }}</div>
    <div style="font-size: 10px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">Derivative Suits</div>
  </div>
</div>
{# D&O Risk context for litigation overview #}
{% set lit_sca_do = lit.get('signal_sca_do_context', '') %}
{% set lit_sec_do = lit.get('signal_sec_do_context', '') %}
{% if lit_sca_do or lit_sec_do %}
<div class="bg-bg-alt border border-gray-200 rounded p-1 mb-3 text-xs text-gray-600 leading-relaxed do-context-cell">
  {% if lit_sca_do %}<p class="mb-1"><strong>SCA D&amp;O Risk:</strong> {{ lit_sca_do | strip_jargon }}</p>{% endif %}
  {% if lit_sec_do %}<p class="mb-0"><strong>SEC D&amp;O Risk:</strong> {{ lit_sec_do | strip_jargon }}</p>{% endif %}
</div>
{% endif %}
{% endif %}
