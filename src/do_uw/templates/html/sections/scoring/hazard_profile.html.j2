{# Hazard Profile (IES) — expandable H1-H7 category cards (SURF-05) #}

{% if hazard_profile %}
<h3>Hazard Profile (Inherent Exposure Score)</h3>
<div class="bg-bg-alt border border-gray-200 rounded p-3 my-2 page-break-inside-avoid">
  <p class="font-heading text-base font-bold text-navy m-0">
    IES: {{ hazard_profile.ies_score }}/100 ({{ hazard_profile.ies_label }})
  </p>
  <p class="text-xs text-gray-500 m-0 mt-1">
    Premium multiplier: {{ hazard_profile.ies_multiplier }} | Data coverage: {{ hazard_profile.data_coverage_pct }}
  </p>
  <p class="text-xs text-gray-400 m-0 mt-1">Measures the company's inherent D&amp;O exposure across 7 hazard categories before considering specific events or claims history</p>
  {% if hazard_profile.confidence_note %}
  <p class="text-xs text-gray-400 italic m-0 mt-1">{{ hazard_profile.confidence_note }}</p>
  {% endif %}
</div>

{% if hazard_profile.top_risk_dimensions %}
{# Split into dimensions WITH evidence vs baseline/default #}
{% set dims_with_evidence = [] %}
{% set dims_baseline = [] %}
{% for d in hazard_profile.top_risk_dimensions %}
  {% if d.evidence %}{% set _ = dims_with_evidence.append(d) %}
  {% else %}{% set _ = dims_baseline.append(d) %}{% endif %}
{% endfor %}
{% if dims_with_evidence %}
<h4>Top Risk Dimensions (Evidence-Based)</h4>
<table class="w-full border-collapse my-3 text-sm">
  <thead>
    <tr class="bg-navy text-white">
      <th class="font-heading text-xs font-semibold uppercase tracking-wider text-left p-1" style="width:30%">Dimension</th>
      <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right p-1" style="width:8%">Score</th>
      <th class="font-heading text-xs font-semibold uppercase tracking-wider text-left p-1" style="width:12%">Exposure</th>
      <th class="font-heading text-xs font-semibold uppercase tracking-wider text-left p-1" style="width:50%">Evidence</th>
    </tr>
  </thead>
  <tbody>
    {% for d in dims_with_evidence %}
    <tr class="{{ 'bg-bg-alt' if loop.index is odd else 'bg-white' }}">
      <td class="p-1 font-semibold">{{ d.name }}</td>
      <td class="p-1 text-right tabular-nums">{{ d.score }}</td>
      <td class="p-1">
        {% if d.exposure_level == 'CRITICAL' %}<span class="text-red-700 font-bold">{{ d.exposure_level }}</span>
        {% elif d.exposure_level == 'HIGH' %}<span class="text-red-600 font-semibold">{{ d.exposure_level }}</span>
        {% else %}<span class="text-amber-600 font-semibold">{{ d.exposure_level }}</span>{% endif %}
      </td>
      <td class="p-1 text-xs text-gray-600">{{ d.evidence | humanize_evidence }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}
{% if dims_baseline %}
<h4>Additional Elevated Dimensions (Sector/Config Defaults)</h4>
<p class="text-xs text-gray-500 mb-2">These dimensions are elevated based on sector classification or configuration defaults. No company-specific evidence was found.</p>
<div class="flex flex-wrap gap-2 my-2">
  {% for d in dims_baseline %}
  <span class="inline-block px-2 py-1 text-xs rounded border
    {% if d.exposure_level == 'CRITICAL' %}border-red-300 bg-red-50 text-red-700
    {% elif d.exposure_level == 'HIGH' %}border-red-200 bg-red-50 text-red-600
    {% else %}border-amber-200 bg-amber-50 text-amber-700{% endif %}">
    {{ d.name }} <span class="font-semibold">{{ d.score }}</span>
  </span>
  {% endfor %}
</div>
{% endif %}
{% endif %}

{% if hazard_profile.interactions %}
<h4>Interaction Effects
  <span class="text-sm font-normal text-gray-500">
    (Combined: {{ hazard_profile.interaction_multiplier }})
  </span>
</h4>

{% if hazard_profile.named_interactions %}
<div class="space-y-2 my-2">
  {% for ie in hazard_profile.named_interactions %}
  <div class="interaction-card border-l-3 border-amber-500 pl-3 py-2 bg-amber-50 rounded-r">
    <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
      <span class="font-semibold text-sm">{{ ie.name }}</span>
      <span class="badge-pill" style="background: #d97706; color: white;">{{ ie.multiplier }}</span>
      <span class="text-xs text-gray-400">Named Pattern</span>
    </div>
    <p class="text-xs text-gray-600 m-0 mt-1">{{ ie.description }}</p>
    {% if ie.triggered_dims %}
    <div class="mt-1">
      <span class="text-xs text-gray-400">Active Dimensions:</span>
      {% for dim_id in ie.triggered_dims %}
      <span class="inline-block px-1 py-0.5 text-xs rounded bg-white border border-gray-200 mr-1">{{ dim_id }}</span>
      {% endfor %}
    </div>
    {% endif %}
  </div>
  {% endfor %}
</div>
{% endif %}

{% if hazard_profile.dynamic_interactions %}
<div>
  <div style="font-weight:600;margin-bottom:4px">Dynamic Interactions ({{ hazard_profile.dynamic_interactions|length }})</div>
  <div class="space-y-2 mt-2 px-2">
    {% for ie in hazard_profile.dynamic_interactions %}
    <div class="border-l-3 border-gray-300 pl-3 py-1">
      <div style="display:flex; align-items:center; gap:0.5rem;">
        <span class="font-semibold text-sm">{{ ie.name }}</span>
        <span class="text-xs tabular-nums font-mono">{{ ie.multiplier }}</span>
      </div>
      <p class="text-xs text-gray-500 m-0">{{ ie.description }}</p>
      <span class="text-xs text-gray-400">Dims: {{ ie.triggered_dims_display }}</span>
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}
{% endif %}

{# --- Expandable H1-H7 Category Cards (SURF-05: all dimensions visible) --- #}
{% if hazard_profile.categories_with_dimensions is defined and hazard_profile.categories_with_dimensions %}
<h4>Hazard Categories ({{ hazard_profile.all_dimensions|length }} Dimensions)</h4>
{% for cat in hazard_profile.categories_with_dimensions %}
{# Check if Data column has any real data (not all default/neutral) #}
{% set ns_hzd = namespace(show_data=false) %}
{% for d in cat.dimensions %}{% if d.data_available %}{% set ns_hzd.show_data = true %}{% endif %}{% endfor %}
<div>
  <div style="font-weight:600;margin-bottom:4px">
    <span class="hazard-cat-code">{{ cat.category_code }}</span>
    <span class="hazard-cat-name">{{ cat.category_name }}</span>
    <span class="hazard-cat-score tabular-nums">{{ cat.weighted_score }}</span>
    <span class="hazard-cat-dims">{{ cat.dimension_count }} dims</span>
    {% if cat.elevated_count > 0 %}
    <span class="badge-pill badge-tier-warning">{{ cat.elevated_count }} elevated</span>
    {% endif %}
    <span class="text-xs text-gray-400">{{ cat.data_coverage }} coverage</span>
  </div>
  <table class="w-full border-collapse text-xs my-1">
    <thead>
      <tr class="bg-gray-100">
        <th class="text-left px-2 py-1 border-b">ID</th>
        <th class="text-left px-2 py-1 border-b">Dimension</th>
        <th class="text-right px-2 py-1 border-b">Score</th>
        <th class="text-left px-2 py-1 border-b">Exposure</th>
        <th class="text-left px-2 py-1 border-b">Evidence</th>
        {% if ns_hzd.show_data %}<th class="text-center px-2 py-1 border-b">Data</th>{% endif %}
      </tr>
    </thead>
    <tbody>
      {% for d in cat.dimensions %}
      <tr class="{{ 'bg-bg-alt' if loop.index is odd else 'bg-white' }}"
          {% if d.evidence %}title="{{ d.evidence | humanize_evidence }}"{% endif %}>
        <td class="px-2 py-1 border-b border-gray-100 text-gray-400">{{ d.dimension_id }}</td>
        <td class="px-2 py-1 border-b border-gray-100">{{ d.name }}</td>
        <td class="px-2 py-1 border-b border-gray-100 text-right tabular-nums">{{ d.score }}</td>
        <td class="px-2 py-1 border-b border-gray-100">
          {% if d.exposure_level == 'CRITICAL' %}<span class="text-red-700 font-bold">{{ d.exposure_level }}</span>
          {% elif d.exposure_level == 'HIGH' %}<span class="text-red-600 font-semibold">{{ d.exposure_level }}</span>
          {% elif d.exposure_level == 'ELEVATED' %}<span class="text-amber-600 font-semibold">{{ d.exposure_level }}</span>
          {% else %}<span class="text-gray-500">{{ d.exposure_level }}</span>{% endif %}
        </td>
        <td class="px-2 py-1 border-b border-gray-100 text-gray-400 text-xs">{{ d.evidence | humanize_evidence }}</td>
        {% if ns_hzd.show_data %}
        <td class="px-2 py-1 border-b border-gray-100 text-center">
          {% if d.data_available %}
          <span class="confidence-dot confidence-high" title="Data available"></span>
          {% else %}
          <span class="confidence-dot confidence-low" title="Default/neutral"></span>
          {% endif %}
        </td>
        {% endif %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endfor %}
{% else %}
{# Fallback: flat dimension list if categories_with_dimensions not available #}
<div>
  <div style="font-weight:600;margin-bottom:4px">All {{ hazard_profile.all_dimensions|length }} Hazard Dimensions</div>
  <table class="w-full border-collapse my-2 text-xs">
    <thead>
      <tr class="bg-gray-100">
        <th class="text-left px-2 py-1 border-b">#</th>
        <th class="text-left px-2 py-1 border-b">Dimension</th>
        <th class="text-right px-2 py-1 border-b">Score</th>
        <th class="text-left px-2 py-1 border-b">Exposure</th>
        <th class="text-left px-2 py-1 border-b">Category</th>
        <th class="text-left px-2 py-1 border-b">Evidence</th>
      </tr>
    </thead>
    <tbody>
      {% for d in hazard_profile.all_dimensions %}
      <tr class="{{ 'bg-bg-alt' if loop.index is odd else 'bg-white' }}">
        <td class="px-2 py-1 border-b border-gray-100 text-gray-400">{{ loop.index }}</td>
        <td class="px-2 py-1 border-b border-gray-100">{{ d.name }}</td>
        <td class="px-2 py-1 border-b border-gray-100 text-right tabular-nums">{{ d.score }}</td>
        <td class="px-2 py-1 border-b border-gray-100">{{ d.exposure_level }}</td>
        <td class="px-2 py-1 border-b border-gray-100 text-gray-500">{{ d.category_name }}</td>
        <td class="px-2 py-1 border-b border-gray-100 text-gray-400">{{ d.evidence | humanize_evidence }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endif %}

{% else %}
<h3>Hazard Profile</h3>
{{ gap_notice("Hazard Profile", "Hazard profile data not available") }}
{% endif %}
