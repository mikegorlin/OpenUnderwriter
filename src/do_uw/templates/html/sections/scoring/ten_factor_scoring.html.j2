{# 10-Factor Scoring Table — extracted from scoring.html.j2 #}
{% set factors = sc.get('factors', []) %}
{% if factors %}
<h3>10-Factor Scoring</h3>
<table class="w-full border-collapse my-3 text-sm">
  <thead>
    <tr class="bg-navy text-white">
      <th class="font-heading text-xs font-semibold uppercase tracking-wider text-left p-1">Factor</th>
      <th class="font-heading text-xs font-semibold uppercase tracking-wider text-left p-1">Name</th>
      <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right p-1">Score</th>
      <th class="font-heading text-xs font-semibold uppercase tracking-wider text-right p-1">Max</th>
      <th class="font-heading text-xs font-semibold uppercase tracking-wider text-center p-1">Impact</th>
      <th class="font-heading text-xs font-semibold uppercase tracking-wider text-left p-1">Risk Level</th>
      <th class="font-heading text-xs font-semibold uppercase tracking-wider text-left p-1">D&amp;O Risk</th>
    </tr>
  </thead>
  <tbody class="tabular-nums">
    {% for factor in factors %}
    <tr class="{{ 'bg-bg-alt' if loop.index is odd else 'bg-white' }} heat-factor" style="--intensity: {{ (factor.get('pct', 0) / 100) | round(2) }}">
      <td class="p-1 font-heading text-xs font-semibold text-navy">{{ factor.id }}</td>
      <td class="p-1">
        {{ factor.name }}
        {% if factor.get('role') %}
        <span class="ml-1 inline-block text-[10px] font-semibold uppercase tracking-wider px-1.5 py-0.5 rounded
          {% if factor.role == 'FREQUENCY' %}bg-blue-100 text-blue-700
          {% elif factor.role == 'SEVERITY' %}bg-orange-100 text-orange-700
          {% else %}bg-purple-100 text-purple-700{% endif %}">{{ factor.role[0] if factor.role != 'BOTH' else 'F+S' }}</span>
        {% endif %}
      </td>
      <td class="p-1 text-right font-semibold
        {% if factor.get('pct', 0) >= 75 %} text-risk-red
        {% elif factor.get('pct', 0) >= 50 %} text-risk-amber
        {% else %} text-navy
        {% endif %}
      ">{{ factor.score }}</td>
      <td class="p-1 text-right text-gray-500">{{ factor.max }}</td>
      <td class="p-1 text-center">
        {% if factor.get('bar_svg') %}{{ factor.bar_svg | safe }}{% endif %}
      </td>
      <td class="p-1">
        {{ traffic_light(factor.get('risk_level', 'INFO'), factor.get('risk_level', '')) }}
      </td>
      <td class="p-1 text-xs text-gray-600 do-context-cell">
        {# Show actual signal evidence (company-specific data), not generic do_context boilerplate #}
        {% if factor.get('all_evidence') %}
          {% for ev in factor.all_evidence[:2] %}
            {{ ev | humanize_evidence }}{% if not loop.last %}; {% endif %}
          {% endfor %}
        {% elif factor.get('signal_attribution') and factor.signal_attribution.get('top_3_signals') %}
          {% for sig in factor.signal_attribution.top_3_signals[:2] %}
            {% if sig.evidence %}{{ sig.evidence | humanize_evidence }}{% if not loop.last %}; {% endif %}{% endif %}
          {% endfor %}
        {% endif %}
      </td>
    </tr>
    {# Evidence detail row for active factors — human-readable, no system internals #}
    {% if factor.get('pct', 0) > 0 and (factor.get('all_evidence') or factor.get('signal_attribution')) %}
    <tr class="{{ 'bg-bg-alt' if loop.index is odd else 'bg-white' }}">
      <td></td>
      <td colspan="6" class="px-3 py-1 text-xs text-gray-500">
        {% if factor.get('all_evidence') %}
        {% for ev in factor.all_evidence %}{{ ev | humanize_evidence }}{% if not loop.last %}; {% endif %}{% endfor %}
        {% endif %}
      </td>
    </tr>
    {% endif %}
    {% endfor %}
  </tbody>
</table>
{# Waterfall + Radar side-by-side charts (Phase 131-03) #}
{% include "sections/scoring/waterfall_radar.html.j2" %}
{# 10-Factor scoring interpretation #}
{% set ns_sf = namespace(max_factor=none, max_pct=0, high_risk=0) %}
{% for factor in factors %}
  {% if factor.get('pct', 0) > ns_sf.max_pct %}
    {% set ns_sf.max_pct = factor.get('pct', 0) %}
    {% set ns_sf.max_factor = factor %}
  {% endif %}
  {% if factor.get('pct', 0) >= 75 %}{% set ns_sf.high_risk = ns_sf.high_risk + 1 %}{% endif %}
{% endfor %}
<ul class="text-xs text-gray-500 mt-1 mb-3 leading-relaxed list-disc pl-4 space-y-0.5">
  {% if ns_sf.high_risk > 0 %}
  <li>{{ ns_sf.high_risk }} factor{{ 's' if ns_sf.high_risk > 1 }} at high risk (75%+ of maximum deduction)</li>
  {% endif %}
  {% if ns_sf.max_factor %}
  <li>Highest deduction: {{ ns_sf.max_factor.name }} ({{ ns_sf.max_factor.score }}/{{ ns_sf.max_factor.max }})</li>
  {% endif %}
  <li>Model weights financial distress, governance deficiencies, litigation exposure, and market signals to produce a composite D&amp;O claim probability estimate</li>
  <li>Factors scoring above 50% of their maximum are highlighted in the detail view below with specific active signals</li>
  <li>Factor roles: <span class="bg-blue-100 text-blue-700 px-1 rounded text-[10px] font-semibold">F</span> = Frequency (drives claim filing probability), <span class="bg-orange-100 text-orange-700 px-1 rounded text-[10px] font-semibold">S</span> = Severity (drives loss amount), <span class="bg-purple-100 text-purple-700 px-1 rounded text-[10px] font-semibold">F+S</span> = Both</li>
</ul>
{# Per-factor collapsible detail — What Was Found + Underwriting Commentary #}
{% include "sections/scoring/factor_detail.html.j2" %}
{# Probability decomposition (Phase 131-03) #}
{% include "sections/scoring/probability_decomposition.html.j2" %}
{% endif %}
