        {
          "triggers_count_range": [
            2,
            3
          ],
          "severity": "ELEVATED",
          "points": 2
        },
        {
          "triggers_count_range": [
            4,
            5
          ],
          "severity": "HIGH",
          "points": 3
        },
        {
          "triggers_count_min": 6,
          "severity": "SEVERE",
          "points": 4
        }
      ],
      "score_impact": {
        "F9": {
          "base": 2,
          "max": 4
        }
      },
      "component_signals": [
        "BIZ.MODEL.sustainability",
        "BIZ.DEPEND.customer_concentration",
        "BIZ.MODEL.revenue_type",
        "BIZ.MODEL.disruption",
        "BIZ.MODEL.leverage_ops"
      ]
    },
    {
      "id": "PATTERN.BIZ.GROWTH_TRAJECTORY",
      "name": "Growth Trajectory Risk",
      "category": "business",
      "allegation_types": [
        "B",
        "A"
      ],
      "description": "Decelerating growth trajectory with elevated market expectations. Classic 'growth darling' risk profile.",
      "trigger_conditions": [
        {
          "field": "consecutive_years_decelerating_revenue",
          "operator": "gte",
          "value": 3,
          "description": "3 consecutive years of decelerating revenue growth"
        },
        {
          "field": "pe_ratio_vs_sector_avg",
          "operator": "gt",
          "value": 2.0,
          "description": "P/E ratio exceeds 2x sector average"
        },
        {
          "field": "analyst_consensus",
          "operator": "eq",
          "value": "BUY",
          "description": "High analyst coverage with consensus BUY",
          "note": "This condition is qualitative - need to define 'high coverage' threshold. Suggested: 10+ analysts covering."
        },
        {
          "field": "provides_specific_growth_guidance",
          "operator": "eq",
          "value": true,
          "description": "Company provides specific growth guidance"
        }
      ],
      "trigger_logic": "deceleration AND elevated_expectations (first 2 conditions required, plus at least 1 of conditions 3-4)",
      "score_impact": {
        "F5": {
          "base": 3,
          "max": 3
        }
      },
      "component_signals": [
        "BIZ.SIZE.geographic_scope",
        "STOCK.ANALYST.coverage",
        "FIN.GUIDE.track_record"
      ],
      "note": "PATTERNS.md maps scoring to F6 (Guidance Miss Risk) but the factor description in scoring_weights.json maps guidance to F5. Using F5 as canonical."
    },
