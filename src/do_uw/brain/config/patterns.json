    {
      "id": "PATTERN.FIN.GUIDANCE_TRACK_RECORD",
      "name": "Guidance Track Record",
      "category": "financial",
      "allegation_types": [
        "B"
      ],
      "description": "Historical pattern of guidance misses indicates management cannot reliably forecast.",
      "trigger_conditions": [
        {
          "any_of": [
            {
              "field": "misses_in_12_quarters",
              "operator": "gte",
              "value": 3,
              "description": "3+ misses in 12 quarters"
            },
            {
              "field": "consecutive_misses",
              "operator": "gte",
              "value": 2,
              "description": "2+ consecutive misses"
            }
          ]
        }
      ],
      "classification": {
        "POOR": "3+ misses in 12 quarters OR 2+ consecutive misses",
        "MODERATE": "1-2 misses in 12 quarters",
        "CLEAN": "Consistently meets/beats"
      },
      "score_impact": {
        "F5": {
          "3_plus_consecutive_misses": 8,
          "2_consecutive_misses": 5,
          "recent_miss_plus_lowered_guidance": 6,
          "1_miss_in_4_quarters": 2,
          "max": 8
        }
      },
      "component_signals": [
        "FIN.GUIDE.track_record",
        "FIN.GUIDE.consistency",
        "FIN.GUIDE.reaction",
        "FWRD.EVENT.earnings_risk"
      ]
    },
    {
      "id": "PATTERN.GOV.TURNOVER_STRESS",
      "name": "Turnover Stress",
      "category": "governance",
      "allegation_types": [
        "D"
      ],
      "description": "Leadership instability pattern suggesting underlying problems. Executive departures during stress periods are red flags for derivative claims.",
