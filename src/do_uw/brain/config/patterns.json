    {
      "id": "PATTERN.FIN.LIQUIDITY_STRESS",
      "name": "Liquidity Stress",
      "category": "financial",
      "allegation_types": [
        "A"
      ],
      "description": "Multiple liquidity warning signs present simultaneously, indicating undisclosed financial distress.",
      "trigger_conditions": [
        {
          "field": "liquidity_stress_signals_count",
          "operator": "gte",
          "value": 4,
          "description": "At least 4 of the following stress signals present"
        }
      ],
      "signal_definitions": [
        {
          "field": "current_ratio_declining_quarters",
          "operator": "gte",
          "value": 3,
          "description": "Current ratio declining 3+ consecutive quarters"
        },
        {
          "field": "cash_position_declining_quarters",
          "operator": "gte",
          "value": 3,
          "description": "Cash position declining 3+ consecutive quarters"
        },
        {
          "field": "working_capital_negative_or_declining_rapidly",
          "operator": "eq",
          "value": true,
          "description": "Working capital negative or declining rapidly"
        },
        {
          "field": "ocf_negative_or_declining",
          "operator": "eq",
          "value": true,
          "description": "Operating cash flow negative or declining"
        },
        {
          "field": "revolver_utilization_pct",
          "operator": "gt",
          "value": 50,
          "description": "Revolver utilization exceeds 50% and rising",
          "note": "'Rising' is qualitative -- need to define as QoQ increase"
        },
        {
          "field": "cash_runway_months",
          "operator": "lt",
          "value": 12,
          "description": "Cash runway below 12 months"
        },
        {
          "field": "debt_covenants_at_risk",
          "operator": "eq",
          "value": true,
          "description": "Debt covenants at risk of breach"
        }
      ],
      "score_impact": {
        "F8": {
          "base": 4,
          "max": 4
        }
      },
