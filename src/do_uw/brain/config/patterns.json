        {
          "field": "cfo_tenure_years",
          "operator": "lt",
          "value": 1,
          "description": "CFO tenure below 1 year"
        },
        {
          "field": "ceo_and_cfo_both_under_1yr",
          "operator": "eq",
          "value": true,
          "description": "Both CEO and CFO tenure under 1 year"
        },
        {
          "field": "csuite_departures_12mo",
          "operator": "gte",
          "value": 2,
          "description": "2+ C-suite departures in 12 months"
        },
        {
          "field": "departure_during_financial_stress",
          "operator": "eq",
