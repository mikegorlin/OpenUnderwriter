{
  "$schema": "PATTERNS_V1",
  "version": "1.0.0",
  "description": "Composite risk patterns for D&O underwriting. Each pattern combines multiple checks to detect higher-order risk indicators.",
  "last_updated": "2026-02-07",
  "source": "SYSTEM/BRAIN/PATTERNS.md v1.0 (2026-01-30)",
  "total_patterns": 19,
  "allegation_types": {
    "A": "Disclosure - 10b-5/Section 11 misstatement/omission claims",
    "B": "Guidance - Forward-looking statement fraud claims",
    "C": "Product/Ops - Operational and product-related claims",
    "D": "Governance - Fiduciary breach and derivative claims",
    "E": "M&A - Merger and acquisition-related claims"
  },
  "categories": {
    "stock": {
      "count": 6,
      "concern": "Stock-based claims, loss causation"
    },
    "business": {
      "count": 4,
      "concern": "Operational fragility, sustainability"
    },
    "financial": {
      "count": 3,
      "concern": "Financial disclosure, guidance fraud"
    },
    "governance": {
      "count": 3,
      "concern": "Fiduciary duties, oversight failures"
    },
    "forward": {
      "count": 3,
      "concern": "Prospective disclosure risk"
    }
  },
  "patterns": [
    {
      "id": "PATTERN.STOCK.EVENT_COLLAPSE",
      "name": "Event Collapse",
      "category": "stock",
      "allegation_types": [
        "A",
        "B"
      ],
      "description": "Single-day stock price shock (>15%) caused by a company-specific event while peers remain stable. Most common trigger for securities class actions.",
      "trigger_conditions": [
        {
          "field": "single_day_drop_pct",
          "operator": "gt",
          "value": 15,
          "description": "Single-day drop exceeds 15%"
        },
        {
          "field": "trigger_type",
          "operator": "in",
          "value": [
            "earnings",
            "guidance",
            "fraud",
            "restatement"
          ],
          "description": "Company-specific trigger identified"
        },
        {
          "field": "peer_avg_drop_pct",
          "operator": "lt",
          "value": 5,
          "description": "Peer average drop below 5% (company-specific)"
        }
      ],
      "severity_modifiers": [
        {
          "field": "single_day_drop_pct",
          "operator": "gt",
          "value": 25,
          "points": 1,
          "label": "SEVERE drop"
        },
        {
          "field": "trigger_type",
          "operator": "eq",
          "value": "earnings",
          "points": 1,
          "label": "Earnings trigger"
        },
        {
          "field": "trigger_type",
          "operator": "eq",
          "value": "fraud",
          "points": 2,
          "label": "Fraud trigger"
        }
      ],
      "score_impact": {
        "F2": {
          "base": 2,
          "max": 5
        }
      },
      "component_signals": [
        "STOCK.PRICE.single_day_events",
        "STOCK.PRICE.attribution",
        "STOCK.LIT.existing_action"
      ],
      "litigation_correlation": "18-35%"
    },
    {
      "id": "PATTERN.STOCK.INFORMED_TRADING",
      "name": "Informed Trading",
      "category": "stock",
      "allegation_types": [
        "D",
        "A"
      ],
      "description": "Evidence that insiders positioned ahead of material non-public information. Provides scienter element for 10b-5 claims.",
      "trigger_conditions": [
        {
          "field": "signals_detected_count",
          "operator": "gte",
          "value": 2,
          "description": "At least 2 of the following signals detected"
        }
      ],
      "signal_definitions": [
        {
          "field": "put_volume_ratio_30d",
          "operator": "gt",
          "value": 3.0,
          "description": "Put volume spike >3x average in 30 days before drop"
        },
        {
          "field": "ceo_cfo_sale_value",
          "operator": "gt",
          "value": 1000000,
          "description": "CEO/CFO sale exceeds $1M"
        },
        {
          "field": "insiders_selling_same_window",
          "operator": "gte",
          "value": 3,
          "description": "3+ insiders selling in same window"
        },
        {
          "field": "10b5_1_plan_modified_or_terminated",
          "operator": "eq",
          "value": true,
          "description": "10b5-1 plan modified or terminated"
        }
      ],
      "score_impact": {
        "F2": {
          "type": "multiplier",
          "2_signals": 1.5,
          "3_plus_signals": 2.0,
          "ceo_sold_bonus": 0.25,
          "cap": 15,
          "formula": "F2_Final = MIN(F2_Base x Insider_Multiplier, 15)"
        }
      },
      "component_signals": [
        "STOCK.INSIDER.summary",
        "STOCK.INSIDER.notable_activity",
        "STOCK.INSIDER.10b5_1_analysis",
        "STOCK.INSIDER.cluster_timing",
        "GOV.INSIDER.sales_timing"
      ],
      "litigation_correlation": "12-22%"
    },
    {
      "id": "PATTERN.STOCK.CASCADE",
      "name": "Cascade Decline",
      "category": "stock",
      "allegation_types": [
        "A"
      ],
      "description": "Sustained decline (>20 days) without recovery bounce, suggesting ongoing damage and persistent negative sentiment.",
      "trigger_conditions": [
        {
          "field": "decline_duration_days",
          "operator": "gt",
          "value": 20,
          "description": "Decline persists for more than 20 days"
        },
        {
          "field": "max_bounce_pct",
          "operator": "lt",
          "value": 5,
          "description": "Maximum recovery bounce below 5%"
        },
        {
          "field": "short_interest_trend",
          "operator": "eq",
          "value": "RISING",
          "description": "Short interest trend is rising"
        }
      ],
      "severity_modifiers": [
        {
          "field": "decline_duration_days",
          "operator": "gt",
          "value": 40,
          "points": 1,
          "label": ">40 days decline"
        },
        {
          "field": "short_interest_doubled",
          "operator": "eq",
          "value": true,
          "points": 1,
          "label": "Short interest doubling"
        }
      ],
      "score_impact": {
        "F2": {
          "base": 2,
          "max": 3
        }
      },
      "component_signals": [
        "STOCK.PRICE.returns_multi_horizon",
        "STOCK.PRICE.recovery",
        "STOCK.SHORT.trend"
      ],
      "litigation_correlation": "15-28%"
    },
    {
      "id": "PATTERN.STOCK.PEER_DIVERGENCE",
      "name": "Peer Divergence",
      "category": "stock",
      "allegation_types": [
        "A"
      ],
      "description": "Company stock significantly underperforms direct peers, establishing company-specific causation.",
      "trigger_conditions": [
        {
          "any_of": [
            {
              "field": "company_vs_peer_30d_pct",
              "operator": "lt",
              "value": -15,
              "description": "30-day underperformance vs peers exceeds 15%"
            },
            {
              "field": "company_vs_peer_90d_pct",
              "operator": "lt",
              "value": -20,
              "description": "90-day underperformance vs peers exceeds 20%"
            }
          ]
        }
      ],
      "severity_modifiers": [
        {
          "field": "divergence_gap_pct",
          "operator": "gt",
          "value": 30,
          "points": 1,
          "label": "Gap exceeds 30%"
        },
        {
          "field": "gap_accelerating",
          "operator": "eq",
          "value": true,
          "points": 1,
          "label": "Gap is accelerating"
        }
      ],
      "score_impact": {
        "F2": {
          "base": 3,
          "max": 4
        }
      },
      "component_signals": [
        "STOCK.PRICE.peer_relative",
        "STOCK.PRICE.attribution",
        "BIZ.COMP.peer_litigation"
      ],
      "litigation_correlation": "22-38%"
    },
    {
      "id": "PATTERN.STOCK.DEATH_SPIRAL",
      "name": "Death Spiral",
      "category": "stock",
      "allegation_types": [
        "A",
        "D"
      ],
      "description": "Multi-factor distress pattern indicating company is on trajectory toward delisting or insolvency.",
      "trigger_conditions": [
        {
          "field": "death_spiral_factors_count",
          "operator": "gte",
          "value": 3,
          "description": "At least 3 of the following factors present"
        }
      ],
      "factor_definitions": [
        {
          "field": "stock_price",
          "operator": "lt",
          "value": 5.0,
          "description": "Stock price below $5 (penny stock threshold)"
        },
        {
          "field": "convertibles_pct_market_cap",
          "operator": "gt",
          "value": 20,
          "description": "Convertibles exceed 20% of market cap"
        },
        {
          "field": "short_interest_vs_sector_ratio",
          "operator": "gt",
          "value": 2.0,
          "description": "Short interest exceeds 2x sector average"
        },
        {
          "field": "delisting_warning_received",
          "operator": "eq",
          "value": true,
          "description": "Exchange delisting warning received"
        },
        {
          "field": "cash_runway_months",
          "operator": "lt",
          "value": 12,
          "description": "Cash runway below 12 months"
        }
      ],
      "severity_levels": [
        {
          "factors_count": 3,
          "severity": "DETECTED",
          "f2_points": 3
        },
        {
          "factors_count": 4,
          "severity": "HIGH",
          "f2_points": 5
        },
        {
          "factors_count": 5,
          "severity": "SEVERE",
          "f2_points": 8
        }
      ],
      "score_impact": {
        "F2": {
          "base": 3,
          "max": 8
        },
        "F8": {
          "base": 4,
          "max": 4
        }
      },
      "component_signals": [
        "STOCK.PRICE.position",
        "STOCK.PRICE.delisting_risk",
        "STOCK.SHORT.position",
        "FIN.DEBT.structure",
        "FIN.LIQ.cash_burn"
      ],
      "litigation_correlation": "25-45%",
      "note": "Max impact in PATTERNS.md says +10 (F2 max 8 + F8 base 4 can exceed 10 total across factors)"
    },
    {
      "id": "PATTERN.STOCK.SHORT_ATTACK",
      "name": "Short Seller Attack",
      "category": "stock",
      "allegation_types": [
        "A"
      ],
      "description": "Coordinated short seller campaign targeting the company with fraud allegations. Short seller reports often precede or accompany securities litigation.",
      "trigger_conditions": [
        {
          "field": "short_attack_signals_count",
          "operator": "gte",
          "value": 2,
          "description": "At least 2 of the following signals present"
        }
      ],
      "signal_definitions": [
        {
          "field": "short_seller_report_published",
          "operator": "eq",
          "value": true,
          "description": "Named short seller report published"
        },
        {
          "field": "short_interest_mom_change_pct",
          "operator": "gt",
          "value": 50,
          "description": "Short interest spike >50% month-over-month"
        },
        {
          "field": "stock_drop_on_report_day_pct",
          "operator": "gt",
          "value": 15,
          "description": "Stock drops >15% on report day"
        },
        {
          "field": "company_issued_rebuttal",
          "operator": "eq",
          "value": true,
          "description": "Company issues formal rebuttal"
        },
        {
          "field": "sec_doj_inquiry_post_report",
          "operator": "eq",
          "value": true,
          "description": "SEC/DOJ inquiry announced after report"
        }
      ],
      "score_impact": {
        "F6": {
          "active_attack_with_fraud": 8,
          "post_attack_or_valuation_only": 4,
          "max": 8
        }
      },
      "status_values": [
        "ACTIVE_ATTACK",
        "POST_ATTACK",
        "NO_ATTACK"
      ],
      "component_signals": [
        "STOCK.SHORT.report",
        "STOCK.SHORT.trend",
        "STOCK.PRICE.single_day_events",
        "STOCK.LIT.existing_action"
      ],
      "litigation_correlation": "28-42% (fraud allegations); 12-18% (valuation-only)"
    },
    {
      "id": "PATTERN.BIZ.SUSTAINABILITY_RISK",
      "name": "Sustainability Risk",
      "category": "business",
      "allegation_types": [
        "A",
        "C"
      ],
      "description": "Business model faces existential pressure from multiple concentration and dependency risks.",
      "trigger_conditions": [
        {
          "field": "sustainability_triggers_count",
          "operator": "gte",
          "value": 3,
          "description": "At least 3 of the following triggers present"
        }
      ],
      "signal_definitions": [
        {
          "field": "top_customer_revenue_pct",
          "operator": "gt",
          "value": 40,
          "description": "Customer concentration exceeds 40% single customer"
        },
        {
          "field": "project_based_revenue_pct",
          "operator": "gt",
          "value": 80,
          "description": "Revenue model exceeds 80% project-based"
        },
        {
          "field": "regulatory_dependency",
          "operator": "eq",
          "value": "ENTIRE_MODEL",
          "description": "Entire business model depends on regulatory approval"
        },
        {
          "field": "technology_disruption_risk",
          "operator": "eq",
          "value": "HIGH",
          "description": "Technology disruption risk is HIGH"
        },
        {
          "field": "operating_leverage_high_and_revenue_declining",
          "operator": "eq",
          "value": true,
          "description": "Operating leverage is HIGH with declining revenue"
        },
        {
          "field": "supplier_concentration",
          "operator": "eq",
          "value": "CRITICAL",
          "description": "Supplier concentration is critical"
        }
      ],
      "severity_levels": [
        {
          "triggers_count_range": [
            0,
