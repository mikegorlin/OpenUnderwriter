{
  "$schema": "SCORING_V1",
  "version": "1.0.0",
  "description": "Consolidated D&O underwriting scoring configuration. Merges factor weights, sub-factor thresholds, and tier boundaries into a single authoritative source.",
  "last_updated": "2026-02-07",
  "sources": [
    "scoring_weights.json v2.0 (2026-01-30)",
    "factor_thresholds.json v1.0 (2026-01-28)",
    "tier_boundaries.json v1.0 (2026-01-28)"
  ],
  "scoring_formula": "quality_score = 100 - risk_points",
  "total_points": 100,
  "factors": {
    "F1_prior_litigation": {
      "factor_id": "F.1",
      "name": "Prior Litigation",
      "max_points": 20,
      "weight_pct": 20,
      "description": "Active securities litigation, SEC enforcement, DOJ investigation",
      "confidence": "VALIDATED",
      "historical_lift": 4.2,
      "rules": [
        {
          "id": "F1-001",
          "condition": "Active securities class action",
          "points": 20,
          "triggers_crf": "CRF-001"
        },
        {
          "id": "F1-002",
          "condition": "Securities suit settled <3 years",
          "points": 18
        },
        {
          "id": "F1-003",
          "condition": "Securities suit settled 3-5 years",
          "points": 15
        },
        {
          "id": "F1-004",
          "condition": "Securities suit settled 5-10 years",
          "points": 10
        },
        {
          "id": "F1-005",
          "condition": "SEC enforcement action <5 years",
          "points": 12
        },
        {
          "id": "F1-006",
          "condition": "Derivative suit <5 years",
          "points": 6
        },
        {
          "id": "F1-007",
          "condition": "No prior litigation",
          "points": 0
        }
      ]
    },
    "F2_stock_decline": {
      "factor_id": "F.2",
      "name": "Stock Decline",
      "max_points": 15,
      "weight_pct": 15,
      "description": "Decline from 52-week high with company-specific attribution and insider trading amplifier",
      "confidence": "VALIDATED",
      "historical_lift": 3.8,
      "rules": [
        {
          "id": "F2-001",
          "condition": ">60% decline",
          "points": 15
        },
        {
          "id": "F2-002",
          "condition": "50-60% decline",
          "points": 12
        },
        {
          "id": "F2-003",
          "condition": "40-50% decline",
          "points": 9
        },
        {
          "id": "F2-004",
          "condition": "30-40% decline",
          "points": 6
        },
        {
          "id": "F2-005",
          "condition": "20-30% decline",
          "points": 3
        },
        {
          "id": "F2-006",
          "condition": "<20% decline",
          "points": 0
        }
      ],
      "insider_amplifier": {
        "note": "Insider trading is a severity multiplier, not standalone factor. Provides scienter evidence.",
        "multipliers": [
          {
            "id": "F2-IA01",
            "condition": "Net buying or neutral",
            "multiplier": 1.0
          },
          {
            "id": "F2-IA02",
            "condition": "Routine 10b5-1 sales (established >6mo)",
            "multiplier": 1.0
          },
          {
            "id": "F2-IA03",
            "condition": "Heavy selling (>25% holdings by CEO/CFO)",
            "multiplier": 1.5
          },
          {
            "id": "F2-IA04",
            "condition": "Cluster selling (3+ executives)",
            "multiplier": 2.0
          },
          {
            "id": "F2-IA05",
            "condition": "Pre-announcement selling (<90 days before bad news)",
            "multiplier": 2.5
          }
        ],
        "pattern_integration": {
          "INFORMED_TRADING_2_signals": 1.5,
          "INFORMED_TRADING_3_signals": 2.0,
          "CEO_sold_pre_drop_additional": 0.25
        },
        "calculation": "F.2 Final = MIN(F.2 Base x Insider Multiplier, 15)"
      },
      "bonuses": [
        {
          "id": "F2-007",
          "condition": "Company underperformed sector by >20 ppts",
          "points": 3
        },
        {
          "id": "F2-008",
          "condition": "Event-window >20% sector-adjusted (10-day)",
          "points": 2
        }
      ],
      "pattern_modifiers": [
        {
          "pattern": "EVENT_COLLAPSE",
          "base_points": 2,
          "severity_modifiers": {
            "drop_gt_25": 1,
            "earnings_trigger": 1,
            "fraud_trigger": 2
          }
        },
        {
          "pattern": "CASCADE",
          "base_points": 2,
          "severity_modifiers": {
            "gt_40_days": 1,
            "si_rising": 1
          }
        },
        {
          "pattern": "PEER_DIVERGENCE",
          "base_points": 3,
          "severity_modifiers": {
            "gap_gt_30": 1,
            "accelerating": 1
          }
        },
        {
          "pattern": "DEATH_SPIRAL",
          "base_points": 3,
          "severity_modifiers": {
            "4_factors": 2,
            "5_factors": 3
          }
        },
        {
          "pattern": "SHORT_ATTACK",
          "base_points": 2,
          "severity_modifiers": {
            "hindenburg_mw": 2,
            "fraud_allegations": 2,
            "sec_doj_followup": 3
          }
        }
      ]
    },
    "F3_restatement_audit": {
      "factor_id": "F.3",
      "name": "Restatement/Audit Issues",
      "max_points": 12,
      "weight_pct": 12,
      "description": "Financial restatements, auditor changes, material weaknesses",
      "confidence": "VALIDATED",
      "historical_lift": 4.5,
      "rules": [
        {
          "id": "F3-001",
          "condition": "Restatement <12 months",
          "points": 12,
          "triggers_crf": "CRF-005"
        },
        {
          "id": "F3-002",
          "condition": "Restatement 12-24 months",
          "points": 10
        },
        {
          "id": "F3-003",
          "condition": "Restatement 2-5 years",
          "points": 6
        },
        {
          "id": "F3-004",
          "condition": "Auditor fired/resigned with disagreement",
          "points": 10
        },
        {
          "id": "F3-005",
          "condition": "Material weakness (SOX 404)",
          "points": 5
        },
        {
          "id": "F3-006",
          "condition": "Auditor change (routine rotation)",
          "points": 2
        },
        {
          "id": "F3-007",
          "condition": "Clean",
          "points": 0
        }
      ]
    },
    "F4_ipo_spac_ma": {
      "factor_id": "F.4",
      "name": "IPO/SPAC/M&A",
      "max_points": 10,
      "weight_pct": 10,
      "description": "Recent IPO, SPAC, or M&A activity windows",
      "confidence": "VALIDATED",
      "historical_lift": 2.8,
      "rules": [
        {
          "id": "F4-001",
          "condition": "SPAC merger <18 months",
          "points": 10
        },
        {
          "id": "F4-002",
          "condition": "SPAC merger 18-36 months",
          "points": 7
        },
        {
          "id": "F4-003",
          "condition": "IPO <18 months",
          "points": 8
        },
        {
          "id": "F4-004",
          "condition": "IPO 18-36 months",
          "points": 5
        },
        {
          "id": "F4-005",
          "condition": "Major M&A (>25% market cap) <2 years",
          "points": 6
        },
        {
          "id": "F4-006",
          "condition": "IPO/SPAC >36 months or N/A",
          "points": 0
        }
      ]
    },
    "F5_guidance_misses": {
      "factor_id": "F.5",
      "name": "Guidance Misses",
      "max_points": 10,
      "weight_pct": 10,
      "description": "Missed guidance or earnings expectations (8 quarters)",
      "confidence": "VALIDATED",
      "historical_lift": 2.4,
      "rules": [
        {
          "id": "F5-001",
          "condition": "4+ misses in past 8 quarters",
          "points": 8
        },
        {
          "id": "F5-002",
          "condition": "3 misses",
          "points": 6
        },
        {
          "id": "F5-003",
          "condition": "2 misses",
          "points": 4
        },
        {
          "id": "F5-004",
          "condition": "1 miss",
          "points": 2
        },
        {
          "id": "F5-005",
          "condition": "0 misses",
          "points": 0
        }
      ],
      "bonuses": [
        {
          "id": "F5-006",
          "condition": "Any single miss >15% vs guidance",
          "points": 2
        }
      ],
      "pattern_modifiers": [
        {
          "pattern": "POOR_TRACK_RECORD",
          "condition": "3+ misses in 8Q OR 2+ consecutive",
          "points": 3
        },
        {
          "pattern": "MODERATE_TRACK_RECORD",
          "condition": "2 misses in 8Q",
          "points": 1
        },
        {
          "pattern": "GUIDANCE_WITHDRAWN",
          "condition": "Guidance withdrawn",
          "points": 2
        },
        {
          "pattern": "CONSECUTIVE_ESCALATION",
          "condition": "Current miss follows consecutive misses",
          "points": 2
        }
      ]
    },
    "F6_short_interest": {
      "factor_id": "F.6",
      "name": "Short Interest",
      "max_points": 8,
      "weight_pct": 8,
      "description": "Elevated short interest relative to sector baseline",
      "confidence": "CORRELATED",
      "historical_lift": 2.1,
      "note": "Apply sector baseline adjustments from config/sector_baselines.json",
      "rules": [
        {
          "id": "F6-R01",
          "condition": ">3x sector average",
          "points": 4
        },
        {
          "id": "F6-R02",
          "condition": "2-3x sector average",
          "points": 3
        },
        {
          "id": "F6-R03",
          "condition": "1.5-2x sector average",
          "points": 2
        },
        {
          "id": "F6-R04",
          "condition": "1-1.5x sector average",
          "points": 1
        },
        {
          "id": "F6-R05",
          "condition": "<1x sector average",
          "points": 0
        }
      ],
      "market_cap_modifiers": [
        {
          "id": "F6-M01",
          "condition": "<$1B market cap",
          "points": 2
        },
        {
          "id": "F6-M02",
          "condition": "$1-5B market cap",
          "points": 1
        },
        {
          "id": "F6-M03",
          "condition": ">$5B market cap",
          "points": 0
        }
      ],
      "trend_modifiers": [
        {
          "id": "F6-D01",
          "condition": "SI increased >50%",
          "points": 2
        },
        {
          "id": "F6-D02",
          "condition": "SI increased 25-50%",
          "points": 1
        },
        {
          "id": "F6-D03",
          "condition": "SI stable (+/-25%)",
          "points": 0
        },
        {
          "id": "F6-D04",
          "condition": "SI decreased >25%",
          "points": -1
        }
      ],
      "short_report_override": [
        {
          "id": "F6-X01",
          "condition": "Named report <6 months",
          "minimum_points": 6,
          "triggers_crf": "CRF-008"
        },
        {
          "id": "F6-X02",
          "condition": "Named report 6-12 months",
          "minimum_points": 4
        }
      ]
    },
    "F7_volatility": {
      "factor_id": "F.7",
      "name": "Stock Volatility",
      "max_points": 9,
      "weight_pct": 9,
      "description": "90-day volatility relative to sector baseline",
      "confidence": "CORRELATED",
      "historical_lift": 1.9,
      "note": "Compare to sector ETF volatility from config/sector_baselines.json",
      "rules": [
        {
          "id": "F7-R01",
          "condition": ">3x sector ETF volatility",
          "points": 4
        },
        {
          "id": "F7-R02",
          "condition": "2-3x sector ETF volatility",
          "points": 3
        },
        {
          "id": "F7-R03",
          "condition": "1.5-2x sector ETF volatility",
          "points": 2
        },
        {
          "id": "F7-R04",
          "condition": "1-1.5x sector ETF volatility",
          "points": 1
        },
        {
          "id": "F7-R05",
          "condition": "<1x sector ETF volatility",
          "points": 0
        }
      ],
      "trend_modifiers": [
        {
          "id": "F7-D01",
          "condition": "Vol increased >100% vs 6mo ago",
          "points": 2
        },
        {
          "id": "F7-D02",
          "condition": "Vol increased 50-100%",
          "points": 1
        },
        {
          "id": "F7-D03",
          "condition": "Vol stable (+/-50%)",
          "points": 0
        },
        {
          "id": "F7-D04",
          "condition": "Vol decreased >50%",
          "points": -1
        }
      ],
      "extreme_events": [
        {
          "id": "F7-E01",
          "condition": "5+ days with >5% single-day move (past 90d)",
          "points": 2
        },
        {
          "id": "F7-E02",
          "condition": "3-4 days with >5% single-day move",
          "points": 1
        },
        {
          "id": "F7-E03",
          "condition": "0-2 days with >5% single-day move",
          "points": 0
        }
      ]
    },
    "F8_financial_distress": {
      "factor_id": "F.8",
      "name": "Financial Distress",
      "max_points": 8,
      "weight_pct": 8,
      "description": "Leverage, liquidity, going concern indicators",
      "confidence": "CORRELATED",
      "historical_lift": 2.0,
      "note": "Use sector-specific leverage baselines from config/sector_baselines.json",
      "rules": [
        {
          "id": "F8-L01",
          "condition": "Leverage >critical sector threshold",
          "points": 3
        },
        {
          "id": "F8-L02",
          "condition": "Leverage elevated to critical",
          "points": 2
        },
        {
          "id": "F8-L03",
          "condition": "Leverage normal to elevated",
          "points": 1
        },
        {
          "id": "F8-L04",
          "condition": "Leverage below normal",
          "points": 0
        }
      ],
      "cash_runway": [
        {
          "id": "F8-C01",
          "condition": "<6 months cash runway",
          "points": 4
        },
        {
          "id": "F8-C02",
          "condition": "6-12 months cash runway",
          "points": 2
        },
        {
          "id": "F8-C03",
          "condition": "12-18 months cash runway",
          "points": 1
        },
        {
          "id": "F8-C04",
          "condition": ">18 months or cash flow positive",
          "points": 0
        }
      ],
      "trend_modifiers": [
        {
          "id": "F8-T01",
          "condition": "Leverage increased >50% YoY",
          "points": 1
        },
        {
          "id": "F8-T02",
          "condition": "Cash declined >40% QoQ (non-seasonal)",
          "points": 1
        },
        {
          "id": "F8-T03",
          "condition": "EBITDA margin declined >500bps YoY",
          "points": 1
        },
        {
          "id": "F8-T04",
          "condition": "Metrics improving (leverage down, cash up)",
          "points": -1
        }
      ],
      "hard_triggers": [
        {
          "id": "F8-X01",
          "condition": "Going concern opinion",
          "points": 6,
          "triggers_crf": "CRF-004"
        },
        {
          "id": "F8-X02",
          "condition": "Covenant breach or waiver",
          "minimum_points": 4
        },
        {
          "id": "F8-X03",
          "condition": "Missed debt payment",
          "points": 6
        },
        {
          "id": "F8-X04",
          "condition": "Credit rating downgrade to junk (<BBB-) in past 12mo",
          "points": 2
        }
      ]
    },
    "F9_governance": {
      "factor_id": "F.9",
      "name": "Governance Issues",
      "max_points": 6,
      "weight_pct": 6,
      "description": "Board independence, compensation concerns, shareholder activism",
      "confidence": "HYPOTHESIS",
      "historical_lift": 1.3,
      "note": "Low direct correlation to claims; narrative/context factor",
      "rules": [
        {
          "id": "F9-001",
          "condition": "CEO = Chairman + Board independence <50%",
          "points": 3
        },
        {
          "id": "F9-002",
          "condition": "CEO = Chairman alone",
          "points": 2
        },
        {
          "id": "F9-003",
          "condition": "Board independence <66% alone",
          "points": 2
        },
        {
          "id": "F9-004",
          "condition": "CEO tenure <6 months",
          "points": 1
        },
        {
          "id": "F9-005",
          "condition": "CFO tenure <6 months",
          "points": 1
        },
        {
          "id": "F9-006",
          "condition": "Strong governance",
          "points": 0
        }
      ],
      "dual_class_override": {
        "condition": "Dual-class structure",
        "points": 3,
        "note": "Automatic 3 points if dual-class"
      },
      "pattern_modifiers": [
        {
          "pattern": "TURNOVER_STRESS",
          "condition": "3+ of: CEO <2yr, CFO <1yr, CCO/CAO turnover, multiple same quarter, departures <vesting",
          "points": 1
        },
        {
          "pattern": "CREDIBILITY_RISK",
          "condition": "6+ triggers from guidance misses, forecast volatility, management conflicts, tone analysis",
          "points": 1,
          "also_affects": "F.5"
        },
        {
          "pattern": "PROXY_ADVISOR_RISK",
          "condition": "ISS QualityScore decile 8-10 OR multiple Withhold recommendations",
          "points": 1
        }
      ]
    },
    "F10_officer_stability": {
      "factor_id": "F.10",
      "name": "Officer Stability",
      "max_points": 2,
      "weight_pct": 2,
      "description": "CEO/CFO tenure and succession planning",
      "confidence": "HYPOTHESIS",
      "historical_lift": 1.2,
      "note": "Extracted from governance; officer turnover as leading indicator",
      "rules": [
        {
          "id": "F10-001",
          "condition": "CEO >2 years AND CFO >1 year",
          "points": 0
        },
        {
          "id": "F10-002",
          "condition": "CEO <2 years OR CFO <1 year",
          "points": 1
        },
        {
          "id": "F10-003",
          "condition": "Both CEO <2yr AND CFO <1yr",
          "points": 2
        },
        {
          "id": "F10-004",
          "condition": "Interim CEO or CFO",
          "points": 2
        }
      ]
    }
  },
  "thresholds": {
    "F2_stock_decline": {
      "factor_id": "F.2",
      "metric": "decline_from_52w_high",
      "unit": "percentage",
      "direction": "higher_is_worse",
      "ranges": [
        {
          "min_pct": 60,
          "max_pct": 100,
          "points": 15,
          "label": "Severe"
        },
        {
          "min_pct": 50,
          "max_pct": 60,
          "points": 12,
          "label": "High"
        },
        {
          "min_pct": 40,
          "max_pct": 50,
          "points": 9,
          "label": "Elevated"
        },
        {
          "min_pct": 30,
          "max_pct": 40,
          "points": 6,
          "label": "Moderate"
        },
        {
          "min_pct": 20,
          "max_pct": 30,
          "points": 3,
          "label": "Low"
        },
        {
          "min_pct": 0,
          "max_pct": 20,
          "points": 0,
          "label": "Normal"
        }
      ]
    },
    "F6_short_interest": {
      "factor_id": "F.6",
      "metric": "short_interest_vs_sector",
      "unit": "percentage_of_float",
      "direction": "higher_is_worse",
      "note": "Apply sector baseline from sector_baselines.json",
      "ranges": [
        {
          "min_pct": 20,
          "max_pct": 100,
          "points": 8,
          "label": "Extreme"
        },
        {
          "min_pct": 15,
          "max_pct": 20,
          "points": 6,
          "label": "High"
        },
        {
          "min_pct": 10,
          "max_pct": 15,
          "points": 4,
          "label": "Elevated"
        },
        {
          "min_pct": 5,
          "max_pct": 10,
          "points": 2,
          "label": "Moderate"
        },
        {
          "min_pct": 0,
          "max_pct": 5,
          "points": 0,
          "label": "Normal"
        }
      ],
      "absolute_ranges_fallback": [
        {
          "category": "Extreme",
          "multiplier": ">2x elevated threshold",
          "points": 6
        },
        {
          "category": "High",
          "points": 4
        },
        {
          "category": "Elevated",
          "points": 2
        },
        {
          "category": "Normal",
          "points": 0
        }
      ]
    },
    "F8_volatility": {
      "factor_id": "F.8",
      "metric": "90_day_volatility",
      "unit": "percentage",
      "direction": "higher_is_worse",
      "note": "90-day annualized volatility, compare to sector ETF",
      "ranges": [
        {
          "min_pct": 60,
          "max_pct": 100,
          "points": 7,
          "label": "Extreme"
        },
        {
          "min_pct": 40,
          "max_pct": 60,
          "points": 5,
          "label": "High"
        },
        {
          "min_pct": 25,
          "max_pct": 40,
          "points": 3,
          "label": "Elevated"
        },
        {
          "min_pct": 0,
          "max_pct": 25,
          "points": 0,
          "label": "Normal"
        }
      ],
      "relative_ranges": [
        {
          "ratio_min": 3.0,
          "ratio_max": null,
          "points": 4,
          "label": ">3x sector"
        },
        {
          "ratio_min": 2.0,
          "ratio_max": 3.0,
          "points": 3,
          "label": "2-3x sector"
        },
        {
          "ratio_min": 1.5,
          "ratio_max": 2.0,
          "points": 2,
          "label": "1.5-2x sector"
        },
        {
          "ratio_min": 1.0,
          "ratio_max": 1.5,
          "points": 1,
          "label": "1-1.5x sector"
        },
        {
          "ratio_min": 0,
          "ratio_max": 1.0,
          "points": 0,
          "label": "<1x sector"
        }
      ]
    },
    "F9_financial_distress": {
      "factor_id": "F.9",
      "metrics": {
        "leverage": {
          "metric": "debt_to_ebitda",
          "note": "Use sector-specific thresholds from sector_baselines.json",
          "default_ranges": [
            {
              "threshold": "distress",
              "points": 3
            },
            {
              "threshold": "critical",
              "points": 2
            },
            {
              "threshold": "elevated",
              "points": 1
            },
            {
              "threshold": "normal",
              "points": 0
            }
          ]
        },
