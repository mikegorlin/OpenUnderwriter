    "maxDepth": 3,
    "maxDescendants": 20,
    "staleTimeoutMs": 300000,
    "messageStalenessTimeoutMs": 180000
  },
  "disabled_mcps": [],
  "disabled_agents": [],
  "disabled_skills": []
}